# JuryPress - Environment Variables Example

# Gemini API Key for generation
GEMINI_API_KEY=your_gemini_api_key_here

# Specific model override (defaults to gemini-3.5-flash)
GEMINI_MODEL=gemini-3.5-flash

# Base URL for Astro build (set in CI automatically for GitHub Pages, e.g., /JuryPress)
# BASE_URL=/JuryPress
# SITE_URL=https://yosuke1024.github.io

# Analytics (Public)
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# AdSense (Public)
PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
PUBLIC_ADSENSE_SLOT_ARTICLE_1=1111111111
PUBLIC_ADSENSE_SLOT_ARTICLE_2=2222222222
PUBLIC_ADSENSE_SLOT_RANKING=3333333333

# External Linking (Public)
PUBLIC_JUDGIE_URL=https://judgie.example.com
PUBLIC_PIXAPPS_URL=https://pixapps.example.com
