---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../lib/base';
---

<Layout 
  title="Licensing | JuryPress" 
  description="Licensing information for JuryPress open-source software, production content, and branding."
>
  <main class="licensing-container">
    <header class="licensing-header">
      <div class="header-eyebrow">LEGAL</div>
      <h1 class="header-title">Licensing & Terms</h1>
      <p class="header-desc">
        JuryPress maintains a strict separation between its open-source software code and its editorial publication data.
      </p>
    </header>

    <div class="licensing-grid">
      <!-- Software Section -->
      <section class="license-card">
        <h2 class="card-title">Software & Technical Assets</h2>
        <p class="card-desc">
          The engine powering JuryPress—including the Astro frontend, structured generation pipeline, evaluator logic, verification test suite, and infrastructure scripts—is open-source software.
        </p>
        <div class="card-meta">
          <span class="license-badge mit">MIT LICENSE</span>
        </div>
        <ul class="card-links">
          <li>
            <a href="https://github.com/yosuke1024/JuryPress/blob/main/LICENSE" target="_blank" rel="noopener">
              View LICENSE File →
            </a>
          </li>
          <li>
            <a href="https://github.com/yosuke1024/JuryPress/blob/main/LICENSING.md" target="_blank" rel="noopener">
              View LICENSING.md Guidelines →
            </a>
          </li>
        </ul>
      </section>

      <!-- Content Section -->
      <section class="license-card">
        <h2 class="card-title">Production Editorial Content</h2>
        <p class="card-desc">
          All published verdicts, simulation reports, rankings, judge commentary, aggregated evidence text, and visual publication media generated by the system are copyright Yosuke Suzuki and are strictly reserved.
        </p>
        <div class="card-meta">
          <span class="license-badge reserved">ALL RIGHTS RESERVED</span>
        </div>
        <p class="card-warning-text">
          No permission is granted to republish, redistribute, sublicense, or build competing products from this dataset except as permitted by copyright law (e.g. fair quotation).
        </p>
      </section>

      <!-- Branding Section -->
      <section class="license-card">
        <h2 class="card-title">Brand Identity</h2>
        <p class="card-desc">
          The JuryPress name, logo, visual design language, assets, and typography remain reserved. No rights are granted to host independent forks of the code under the official "JuryPress" branding or represent them as the official publication.
        </p>
        <div class="card-meta">
          <span class="license-badge reserved">RESERVED</span>
        </div>
      </section>

      <!-- Attribution Section -->
      <section class="license-card">
        <h2 class="card-title">Judgie-AI Derived Assets</h2>
        <p class="card-desc">
          The core AI judge persona definitions, avatar design elements, and evaluation rubrics used in this system are derived from the upstream Judgie-AI project.
        </p>
        <div class="card-meta">
          <span class="license-badge mit">MIT LICENSE (UPSTREAM)</span>
        </div>
        <ul class="card-links">
          <li>
            <a href="https://github.com/yosuke1024/JuryPress/blob/main/ATTRIBUTION.md" target="_blank" rel="noopener">
              View ATTRIBUTION.md Details →
            </a>
          </li>
        </ul>
      </section>
    </div>
  </main>
</Layout>

<style>
  .licensing-container {
    max-width: var(--width-page);
    margin: 0 auto;
    padding: var(--space-12) var(--space-4);
  }

  .licensing-header {
    border-bottom: 1px solid var(--color-rule, #eee);
    padding-bottom: var(--space-8);
    margin-bottom: var(--space-10);
  }

  .header-eyebrow {
    font-family: var(--font-interface);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-accent, #c67c3b);
    margin-bottom: var(--space-2);
  }

  .header-title {
    font-family: var(--font-editorial);
    font-size: 2.8rem;
    color: var(--color-ink, #1a1a2e);
    margin-bottom: var(--space-2);
    font-weight: 800;
    line-height: 1.1;
  }

  .header-desc {
    font-family: var(--font-interface);
    font-size: 1.05rem;
    color: var(--color-ink-muted, #555);
    max-width: 700px;
    line-height: 1.5;
  }

  .licensing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  .license-card {
    background: var(--color-surface-muted, #fafafa);
    border: 1px solid var(--color-rule, #eee);
    border-radius: 8px;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-family: var(--font-editorial);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-ink, #1a1a2e);
    margin-bottom: var(--space-2);
  }

  .card-desc {
    font-family: var(--font-interface);
    font-size: 0.9rem;
    color: var(--color-ink-muted, #555);
    line-height: 1.5;
    margin-bottom: var(--space-4);
    flex-grow: 1;
  }

  .card-meta {
    margin-bottom: var(--space-4);
  }

  .license-badge {
    display: inline-block;
    font-family: var(--font-interface);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .license-badge.mit {
    background: #e8f5e9;
    color: #2e7d32;
  }

  .license-badge.reserved {
    background: #ffe5e5;
    color: #c62828;
  }

  .card-links {
    list-style: none;
    padding-left: 0;
    margin-top: var(--space-2);
  }

  .card-links li {
    margin-bottom: var(--space-1);
  }

  .card-links a {
    font-family: var(--font-interface);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-accent, #c67c3b);
    text-decoration: none;
  }

  .card-links a:hover {
    color: var(--color-accent-hover, #a8622c);
    text-decoration: underline;
  }

  .card-warning-text {
    font-family: var(--font-interface);
    font-size: 0.78rem;
    font-style: italic;
    color: #888;
    margin-top: var(--space-3);
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .licensing-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
