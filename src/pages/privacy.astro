---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Privacy | JuryPress">
  <div class="box">
    <h1>Privacy Policy</h1>
    <p>JuryPress operates as a static site and does not collect personal data on its servers.</p>
    <p>We may use third-party services such as Google Analytics and Google AdSense, which use cookies and collect usage data according to their respective privacy policies.</p>
  </div>
</Layout>
<style>
  .box {
    background: #fafafa;
    border: 1px solid #eee;
    padding: 1.5rem;
    border-radius: 8px;
  }
</style>
