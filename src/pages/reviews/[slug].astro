---
import Layout from '../../layouts/Layout.astro';
import AdSense from '../../components/AdSense.astro';
import Scorecard from '../../components/Scorecard.astro';
import VerdictPlate from '../../components/VerdictPlate.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getAllReviews, sortReviews } from '../../lib/data';
import { withBase } from '../../lib/base';
import { JUDGE_SLUGS } from '../../schemas/jury';
import { TimezoneUtil } from '../../lib/timezone';
import { withUtm } from '../../lib/url';
import { brands } from '../../config/brands';

export async function getStaticPaths() {
  const reviews = getAllReviews();
  return reviews.map(r => ({
    params: { slug: r.slug },
    props: { entry: r },
  }));
}

const { entry } = Astro.props;
const { review, selection, evidence } = entry;
const { product, article, judges } = review.evaluation;

// Ranks Calculation
const allReviews = getAllReviews();
const rankingEligibleReviews = allReviews.filter((r: any) => r.review.ranking_eligible === true);
const sortedOverall = sortReviews(rankingEligibleReviews);
const overallRank = sortedOverall.findIndex((r: any) => r.slug === review.slug) + 1;

const publishedDate = new Date(review.published_at);
const { year, month } = TimezoneUtil.getJSTYearMonth(publishedDate);
const monthStr = `${year}-${month}`;

const sameMonthReviews = rankingEligibleReviews.filter((r: any) => {
  const d = new Date(r.review.published_at);
  const jst = TimezoneUtil.getJSTYearMonth(d);
  return `${jst.year}-${jst.month}` === monthStr;
});
const sortedMonthly = sortReviews(sameMonthReviews);
const monthlyRank = sortedMonthly.findIndex((r: any) => r.slug === review.slug) + 1;

const judgeRanks: Record<string, number> = {};
const judgeNames = JUDGE_SLUGS;
for (const j of judgeNames) {
  const sortedJudge = [...rankingEligibleReviews].sort((a, b) => {
    const scoreA = a.review.evaluation.judges.find((x: any) => x.judge_id === j)?.judge_score || 0;
    const scoreB = b.review.evaluation.judges.find((x: any) => x.judge_id === j)?.judge_score || 0;
    if (scoreA !== scoreB) return scoreB - scoreA;
    // apply same tie-breaks
    const aConf = a.review.evaluation.overall_evidence_confidence || 0;
    const bConf = b.review.evaluation.overall_evidence_confidence || 0;
    if (aConf !== bConf) return bConf - aConf;
    const dateA = new Date(a.review.published_at).getTime();
    const dateB = new Date(b.review.published_at).getTime();
    if (dateA !== dateB) return dateB - dateA;
    return a.slug.localeCompare(b.slug);
  });
  judgeRanks[j] = sortedJudge.findIndex((r: any) => r.slug === review.slug) + 1;
}

const isFixtureMode = review.slug === 'fixture-product';
const siteUrl = Astro.site ? Astro.site.origin : 'https://pixapps.ai';
const canonicalUrl = `${siteUrl}${withBase(`/reviews/${review.slug}/`)}`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  "url": canonicalUrl,
  "mainEntityOfPage": canonicalUrl,
  "itemReviewed": {
    "@type": "SoftwareApplication",
    "name": product.name,
    "applicationCategory": product.category
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": review.jury_score.toFixed(1),
    "bestRating": "100"
  },
  "author": {
    "@type": "Organization",
    "name": "JuryPress"
  },
  "publisher": {
    "@type": "Organization",
    "name": "PixApps",
    "url": brands.pixapps.url
  },
  "datePublished": new Date(review.published_at).toISOString()
};

const directlyVerified = article.evidence_classifications?.filter((c: any) => c.classification === 'source_confirmed' || c.classification === 'verified_fact') || [];
const creatorClaims = article.evidence_classifications?.filter((c: any) => c.classification === 'creator_claim') || [];
const inferences = article.evidence_classifications?.filter((c: any) => c.classification === 'inference') || [];
const unknownClaims = article.evidence_classifications?.filter((c: any) => c.classification === 'unknown') || [];
const runtimeObservations = article.evidence_classifications?.filter((c: any) => c.classification === 'runtime_observed') || [];
---

<Layout 
  title={`${article.headline} - JuryPress`}
  description={article.meta_description}
  ogImage={`/og/${review.slug}.svg`}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
  isArticlePage={true}
>
  <div class="article-layout">
    <!-- Breadcrumbs -->
    <Breadcrumbs items={[{ label: product.name }]} />

    <!-- Article Hero Section -->
    <header class="article-hero">
      <div class="hero-left">
        <div class="article-meta-tags">
          <span class="meta-tag category">{product.category}</span>
          <span class="meta-tag source">{selection.source}</span>
          <span class="meta-tag date tabular-nums">{new Date(review.published_at).toISOString().split('T')[0]}</span>
        </div>
        
        <h1 class="article-headline">{article.headline}</h1>
        <p class="article-standfirst">{article.standfirst}</p>
        
        <!-- Compact Rank Strip -->
        {review.ranking_eligible ? (
          <div class="rank-strip">
            <span class="rank-item">Overall <strong>#{overallRank}</strong></span>
            <span class="rank-divider">|</span>
            <span class="rank-item">{monthStr} <strong>#{monthlyRank}</strong></span>
            {judgeNames.map(j => (
              <>
                <span class="rank-divider">|</span>
                <a href={withBase(`/rankings/judges/${j}/`)} class="rank-link-badge">
                  {j.charAt(0).toUpperCase() + j.slice(1)} <strong>#{judgeRanks[j]}</strong>
                </a>
              </>
            ))}
          </div>
        ) : (
          <div class="rank-strip">
            {(review as any).evaluation_status === 'evidence_limited' ? (
              <span class="rank-item font-bold text-ink-muted">Unranked — Insufficient evidence for a complete assessment</span>
            ) : (
              <span class="rank-item font-bold text-ink-muted">Unranked — Related-party review</span>
            )}
          </div>
        )}
      </div>
      
      <div class="hero-right">
        <VerdictPlate
          juryScore={review.jury_score}
          judgeRange={review.judge_score_range}
          evidenceConfidence={review.evaluation.overall_evidence_confidence || 0}
          isFixture={isFixtureMode}
        />
      </div>
    </header>

    <!-- Translucent, restrained notice bar about automation -->
    <div class="automation-notice-card">
      <span class="notice-icon">🤖</span>
      <p class="notice-text">
        {selection.selection_mode === 'initial-bootstrap' ? (
          "This product was included in JuryPress's initial launch set by the operator. The jury evaluation, scores, and article text were generated automatically. No human edited the jury scores or verdict before first publication."
        ) : (
          "This product was selected by the automated daily curation process. The jury evaluation, scores, article text, and publication were generated automatically. No human edited the jury scores or verdict before first publication."
        )}
      </p>
    </div>

    {review.disclosure && (
      <div class="disclosure-card">
        <span class="disclosure-icon">ℹ️</span>
        <p class="disclosure-text">
          {review.disclosure}
        </p>
      </div>
    )}

    <!-- Selection Details (Initially Folded) -->
    <details class="selection-details">
      <summary class="selection-summary">
        <span class="summary-label">Selection and product details</span>
        <span class="summary-quick-meta">
          Source: <strong>{
            selection.source === 'github' ? 'GitHub' : 
            selection.source === 'hacker-news' ? 'Hacker News' : 
            selection.source === 'hugging-face' ? 'Hugging Face' : 
            selection.source
          }</strong> · 
          {selection.source_metrics && selection.source_metrics.length > 0 && (
            <span>
              Source snapshot: {selection.source_metrics.map((m: any, idx: number) => {
                const formattedPlatform = m.platform === 'github' ? 'GitHub' : m.platform === 'hacker-news' ? 'Hacker News' : m.platform === 'hugging-face' ? 'Hugging Face' : m.platform;
                const formattedUnit = m.platform === 'github' ? 'stars' : m.platform === 'hacker-news' ? 'points' : m.platform === 'hugging-face' ? 'likes' : m.metric;
                const retrievedDate = new Date(m.retrieved_at);
                const formattedDate = retrievedDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                return (
                  <span>
                    {idx > 0 ? ' · ' : ''}
                    {formattedPlatform}: {m.value} {formattedUnit} (Retrieved {formattedDate})
                  </span>
                );
              })} · 
            </span>
          )}
          Website: <a href={selection.canonical_url} target="_blank" rel="noopener" class="summary-url-link">{selection.canonical_url}</a>
        </span>
      </summary>
      <div class="selection-expand-content">
        <div class="details-grid">
          <div class="details-col">
            <h4>Curation Metrics</h4>
            <ul>
              {selection.selection_mode === 'initial-bootstrap' ? (
                <>
                  <li><strong>Selection Mode:</strong> Initial launch set</li>
                  <li><strong>Selected by:</strong> Operator</li>
                </>
              ) : (
                <>
                  <li><strong>Selection Mode:</strong> Automated daily curation</li>
                  <li><strong>Selected by:</strong> System</li>
                  <li><strong>Source Rank:</strong> {selection.source_rank}</li>
                </>
              )}
            </ul>
          </div>
          <div class="details-col">
            <h4>Product Overview</h4>
            <ul>
              <li><strong>Audience:</strong> {product.primary_audience}</li>
              <li><strong>Category:</strong> {product.category}</li>
              <li><strong>Website:</strong> <a href={selection.canonical_url} target="_blank" rel="noopener">{selection.canonical_url}</a></li>
            </ul>
          </div>
        </div>
        <div class="product-summary-block">
          <h4>Product Summary</h4>
          <p>{product.summary}</p>
        </div>
      </div>
    </details>

    <hr class="article-divider" />

    <!-- Editorial Lead: Jury Summary (Narrow width) -->
    <section class="reading-section jury-summary-section">
      <h2 class="section-title">Jury Summary</h2>
      <p class="jury-summary-text">{article.jury_summary}</p>
    </section>

    <!-- Agreements and Disagreements (Split 2-Columns) -->
    <section class="jury-breakdown-section">
      <div class="breakdown-grid">
        <div class="breakdown-col agreed">
          <h3 class="breakdown-title title-agreed">WHERE THE JURY AGREED</h3>
          <ul class="breakdown-list">
            {article.where_jury_agreed.map((point: string) => (
              <li>
                <span class="point-marker check">✓</span>
                <p>{point}</p>
              </li>
            ))}
          </ul>
        </div>
        
        <div class="breakdown-col split">
          <h3 class="breakdown-title title-split">WHERE THE JURY SPLIT</h3>
          <ul class="breakdown-list">
            {article.where_jury_disagreed.map((point: any) => (
              <li>
                <span class="criterion-pill">{point.criterion_id.replace(/_/g, ' ')}</span>
                <p>{point.summary}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Ad Slot (Future Insertion Place) -->
    <AdSense slotId={import.meta.env.PUBLIC_ADSENSE_SLOT_ARTICLE_1} />

    <!-- Detailed scorecards -->
    <section class="judges-scorecards-section">
      <h2 class="scorecards-heading">Five Jury Perspectives</h2>
      <p class="scorecards-subheading">
        Five simulated professional perspectives scored the same public evidence using the JuryPress Open Product Rubric.
      </p>
      
      <div class="scorecards-stack">
        {judges.map((judge: any) => (
          <Scorecard judge={judge} />
        ))}
      </div>
    </section>

    <!-- Final Verdict -->
    <section class="reading-section final-verdict-section">
      <h2 class="verdict-heading">Final Verdict</h2>
      <p class="verdict-body-text">{article.final_verdict}</p>
    </section>

    <!-- Judgie-AI CTA -->
    <section class="reading-section cta-section">
      <div class="judgie-cta-box">
        <h3>Bring the jury to your own project</h3>
        <p>Run the same five AI personas with your own evidence and evaluation criteria using Judgie-AI.</p>
        <a href={withUtm(brands.judgie.url, `article_judgie_${review.slug}`)} class="btn-primary" target="_blank" rel="noopener">
          Explore Judgie-AI →
        </a>
      </div>
    </section>

    <AdSense slotId={import.meta.env.PUBLIC_ADSENSE_SLOT_ARTICLE_2} />

    {review.corrections && review.corrections.length > 0 && (
      <section class="corrections-section">
        <h2 class="section-title">Corrections & Updates</h2>
        <div class="corrections-list-container">
          {review.corrections.map((corr: any) => {
            const corrDate = new Date(corr.corrected_at);
            const formattedCorrDate = corrDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            return (
              <div class="correction-card">
                <div class="correction-meta">
                  <span class="correction-badge">Correction</span>
                  <span class="correction-date tabular-nums">{formattedCorrDate}</span>
                </div>
                <p class="correction-text">{corr.summary}</p>
                {corr.score_changed && (
                  <div class="correction-score-delta">
                    Jury Score updated: <span class="score-old">{corr.previous_score?.toFixed(1)}</span> → <strong class="score-new">{corr.new_score?.toFixed(1)}</strong>
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Evidence and limitations section -->
    <section class="evidence-section">
      <h2 class="section-title">Evidence Sources & Limitations</h2>
      
      <div class="evidence-block">
        <h3>Sources</h3>
        <ul class="sources-list">
          {evidence.map((ev: any) => (
            <li>
              <strong>{ev.evidence_id}</strong>: <a href={ev.url} target="_blank" rel="noopener">{ev.title}</a> ({ev.type})
              <span class="retrieved-time tabular-nums">Retrieved: {ev.retrieved_at}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="evidence-block">
        <h3>Classifications</h3>
        
        {directlyVerified.length > 0 && <h4>Confirmed in supplied source</h4>}
        <ul class="classifications-list">
          {directlyVerified.map((c: any) => {
             const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
             return (
               <li>
                 <span class="class-badge verified">Confirmed</span>
                 <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
               </li>
             );
          })}
        </ul>
        
        {creatorClaims.length > 0 && <h4>Creator Claims</h4>}
        <ul class="classifications-list">
          {creatorClaims.map((c: any) => {
             const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
             return (
               <li>
                 <span class="class-badge claim">Claim</span>
                 <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
               </li>
             );
          })}
        </ul>
        
        {inferences.length > 0 && <h4>Jury Inferences</h4>}
        <ul class="classifications-list">
          {inferences.map((c: any) => {
             const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
             return (
               <li>
                 <span class="class-badge inference">Inference</span>
                 <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
               </li>
             );
          })}
        </ul>

        {runtimeObservations.length > 0 && <h4>Directly Observed During Review</h4>}
        <ul class="classifications-list">
          {runtimeObservations.map((c: any) => {
             const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
             return (
               <li>
                 <span class="class-badge verified">Observed</span>
                 <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
               </li>
             );
          })}
        </ul>
        
        {unknownClaims.length > 0 && <h4>Could Not Assess / Unknown</h4>}
        <ul class="classifications-list">
          {unknownClaims.map((c: any) => {
             const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
             return (
               <li>
                 <span class="class-badge unassessed">Unknown</span>
                 <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
               </li>
             );
          })}
        </ul>
      </div>

      <div class="evidence-block">
        <h3>Limitations</h3>
        <ul class="limitations-list">
          {article.evidence_limitations.map((lim: string) => <li>{lim}</li>)}
        </ul>
      </div>
    </section>
  </div>
</Layout>

<style>
  .article-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  /* Hero Section */
  .article-hero {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-8);
    align-items: flex-start;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .article-meta-tags {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    font-family: var(--font-interface);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .meta-tag {
    background: var(--color-canvas);
    color: var(--color-ink-muted);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meta-tag.category {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .article-headline {
    font-family: var(--font-editorial);
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-ink);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .article-standfirst {
    font-family: var(--font-interface);
    font-size: 1.15rem;
    color: var(--color-ink-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Rank Strip */
  .rank-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-interface);
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin-top: var(--space-2);
  }

  .rank-item {
    font-weight: 500;
  }

  .rank-item strong {
    color: var(--color-ink);
    font-weight: 700;
  }

  .rank-divider {
    color: var(--color-rule);
    user-select: none;
  }

  .rank-link-badge {
    color: var(--color-ink-muted);
    text-decoration: none;
  }

  .rank-link-badge:hover {
    color: var(--color-accent);
  }

  .rank-link-badge strong {
    color: var(--color-accent);
  }

  /* Automation Notice */
  .automation-notice-card {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-sm);
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .notice-icon {
    font-size: 1.25rem;
  }

  .notice-text {
    font-family: var(--font-interface);
    font-size: 0.88rem;
    color: var(--color-ink-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Disclosure Notice */
  .disclosure-card {
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-sm);
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .disclosure-icon {
    font-size: 1.25rem;
  }

  .disclosure-text {
    font-family: var(--font-interface);
    font-size: 0.88rem;
    color: var(--color-ink-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Selection Details disclosure */
  .selection-details {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
  }

  .selection-summary {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--space-4);
  }

  .summary-label {
    font-family: var(--font-interface);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-ink);
  }

  .summary-quick-meta {
    font-family: var(--font-interface);
    font-size: 0.82rem;
    color: var(--color-ink-muted);
  }

  .summary-url-link {
    color: var(--color-accent);
  }

  .selection-expand-content {
    padding: 0 var(--space-4) var(--space-4);
    border-top: 1px solid var(--color-canvas);
    font-family: var(--font-interface);
    font-size: 0.88rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    padding-top: var(--space-4);
  }

  .details-col h4, .product-summary-block h4 {
    font-family: var(--font-interface);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-ink-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .details-col ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .details-col li {
    color: var(--color-ink-muted);
  }

  .product-summary-block p {
    color: var(--color-ink-muted);
    line-height: 1.6;
  }

  .article-divider {
    border: none;
    border-top: 1px solid var(--color-rule);
    margin: var(--space-4) 0;
  }

  /* Narrow Reading Section Utility */
  .reading-section {
    max-width: 720px; /* --width-reading: 720px */
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .section-title {
    font-family: var(--font-editorial);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-ink);
  }

  .jury-summary-text {
    font-family: var(--font-interface);
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-ink);
  }

  /* Agreements & Disagreements Section */
  .breakdown-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  .breakdown-col {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .breakdown-title {
    font-family: var(--font-interface);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0;
  }

  .title-agreed {
    color: var(--color-positive);
  }

  .title-split {
    color: var(--color-accent);
  }

  .breakdown-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
