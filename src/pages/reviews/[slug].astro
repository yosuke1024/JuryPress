---
import Layout from '../../layouts/Layout.astro';
import AdSense from '../../components/AdSense.astro';
import Scorecard from '../../components/Scorecard.astro';
import VerdictPlate from '../../components/VerdictPlate.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ReviewDiscussion from '../../components/ReviewDiscussion.astro';
import { getAllReviews, sortReviews } from '../../lib/data';
import { withBase } from '../../lib/base';
import { JUDGE_SLUGS } from '../../schemas/jury';
import { TimezoneUtil } from '../../lib/timezone';
import { withUtm } from '../../lib/url';
import { brands } from '../../config/brands';
import { summarizeStatementProvenance, supportModeLabel, sourceProvenanceLabel } from '../../lib/evaluation/statement-provenance';

export async function getStaticPaths() {
  const reviews = getAllReviews();
  return reviews.map(r => ({
    params: { slug: r.slug },
    props: { entry: r },
  }));
}

const { entry } = Astro.props;
const { review, selection, evidence } = entry;
const { product, article, judges } = review.evaluation;

// Ranks Calculation
const allReviews = getAllReviews();
const rankingEligibleReviews = allReviews.filter((r: any) => r.review.ranking_eligible === true);
const sortedOverall = sortReviews(rankingEligibleReviews);
const overallRank = sortedOverall.findIndex((r: any) => r.slug === review.slug) + 1;

const publishedDate = new Date(review.published_at);
const { year, month } = TimezoneUtil.getJSTYearMonth(publishedDate);
const monthStr = `${year}-${month}`;

const sameMonthReviews = rankingEligibleReviews.filter((r: any) => {
  const d = new Date(r.review.published_at);
  const jst = TimezoneUtil.getJSTYearMonth(d);
  return `${jst.year}-${jst.month}` === monthStr;
});
const sortedMonthly = sortReviews(sameMonthReviews);
const monthlyRank = sortedMonthly.findIndex((r: any) => r.slug === review.slug) + 1;

const judgeRanks: Record<string, number> = {};
const judgeNames = JUDGE_SLUGS;
for (const j of judgeNames) {
  const sortedJudge = [...rankingEligibleReviews].sort((a, b) => {
    const scoreA = a.review.evaluation.judges.find((x: any) => x.judge_id === j)?.judge_score || 0;
    const scoreB = b.review.evaluation.judges.find((x: any) => x.judge_id === j)?.judge_score || 0;
    if (scoreA !== scoreB) return scoreB - scoreA;
    // apply same tie-breaks
    const aConf = a.review.evaluation.overall_evidence_confidence || 0;
    const bConf = b.review.evaluation.overall_evidence_confidence || 0;
    if (aConf !== bConf) return bConf - aConf;
    const dateA = new Date(a.review.published_at).getTime();
    const dateB = new Date(b.review.published_at).getTime();
    if (dateA !== dateB) return dateB - dateA;
    return a.slug.localeCompare(b.slug);
  });
  judgeRanks[j] = sortedJudge.findIndex((r: any) => r.slug === review.slug) + 1;
}

const isFixtureMode = review.slug === 'fixture-product';
const siteUrl = Astro.site ? Astro.site.origin : 'https://pixapps.ai';
const canonicalUrl = `${siteUrl}${withBase(`/reviews/${review.slug}/`)}`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  "url": canonicalUrl,
  "mainEntityOfPage": canonicalUrl,
  "itemReviewed": {
    "@type": "SoftwareApplication",
    "name": product.name,
    "applicationCategory": product.category
  },
  // evidence_limited reviews carry jury_score: null — they publish without a rating.
  ...(review.jury_score !== null && review.jury_score !== undefined ? {
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": review.jury_score.toFixed(1),
      "bestRating": "100"
    }
  } : {}),
  "author": {
    "@type": "Organization",
    "name": "JuryPress"
  },
  "publisher": {
    "@type": "Organization",
    "name": "PixApps",
    "url": brands.pixapps.url
  },
  "datePublished": new Date(review.published_at).toISOString()
};

// Refined reviews (evaluation_integrity_version 1.0.0) carry application-derived
// classifications in the EvidenceFactClass vocabulary; legacy reviews keep their
// model-authored values. Rendering branches so legacy display is byte-identical while
// refined reviews preserve community_opinion / repository_observation / unverified.
const isRefinedEvaluation = review.evaluation.evaluation_integrity_version === '1.0.0';
const classificationsList = article.evidence_classifications || [];

/**
 * Editorial (3.0.0) reviews render a different appendix: the article carries no provenance
 * apparatus of its own, and the statement-to-evidence relationship lives in the separate,
 * regenerable evidence map. It is shown collapsed at the bottom — a reference, never the
 * hero — and its absence is a normal state, not an error. No coverage percentage is shown
 * anywhere: a score on the audit would invite readers to grade the bookkeeping instead of
 * reading the review.
 */
const isEditorialReview = review.schema_version === '3.0.0';
const evidenceMap = entry.evidenceMap ?? null;

const CLAIM_CLASSIFICATION_LABELS: Record<string, { label: string; badge: string }> = {
  directly_supported: { label: 'Directly supported', badge: 'verified' },
  repository_observation: { label: 'Repository observation', badge: 'verified' },
  creator_claim: { label: 'Creator claim', badge: 'claim' },
  community_opinion: { label: 'Community opinion', badge: 'claim' },
  reasonable_inference: { label: 'Jury inference', badge: 'inference' },
  editorial_judgment: { label: 'Editorial judgment', badge: 'inference' },
  not_linked_to_collected_evidence: { label: 'Not linked to collected evidence', badge: 'unassessed' },
  contradicted_by_evidence: { label: 'Contradicted by evidence', badge: 'unassessed' }
};

// One row per classification, in the taxonomy's own order — a neutral breakdown of how the
// review's statements relate to the material, with no coverage percentage.
const claimClassificationRows = evidenceMap
  ? Object.keys(CLAIM_CLASSIFICATION_LABELS)
      .map(key => ({
        key,
        ...CLAIM_CLASSIFICATION_LABELS[key],
        count: evidenceMap.claims.filter(claim => claim.classification === key).length
      }))
      .filter(row => row.count > 0)
  : [];

// Coverage is stated in absolute counts, never as a score. A breakdown shown without them
// reads as "this is the whole article", which for a partial map is false by omission.
// Maps written before scoping existed carry no scope — for those the counts are simply not
// reported rather than reconstructed, since the denominator genuinely isn't known.
const mappedStatementCount = evidenceMap?.claims.length ?? 0;
const mapScope = evidenceMap?.scope ?? null;
const isPartialMap = review.evidence_map_status === 'partial';

// Refined-only statement provenance summary. Statement mode (evidence-backed / inference /
// unverified) and source provenance (which fact classes the cited evidence carries) are two
// different axes: an inference grounded on the README stays identifiable as an inference
// AND keeps its creator-claim provenance. Legacy reviews produce no groups and render
// exactly as before.
const statementProvenanceGroups = isRefinedEvaluation
  ? summarizeStatementProvenance(review.evaluation.claim_references)
  : [];

// Refined buckets (fact-class vocabulary)
const refinedConfirmedFacts = classificationsList.filter((c: any) => c.classification === 'confirmed_fact');
const refinedRepositoryObservations = classificationsList.filter((c: any) => c.classification === 'repository_observation');
const refinedCreatorClaims = classificationsList.filter((c: any) => c.classification === 'creator_claim');
const refinedCommunityOpinions = classificationsList.filter((c: any) => c.classification === 'community_opinion');
const refinedInferences = classificationsList.filter((c: any) => c.classification === 'inference');
const refinedUnverified = classificationsList.filter((c: any) => c.classification === 'unverified');
const refinedRuntimeObserved = classificationsList.filter((c: any) => c.classification === 'runtime_observed');

// Legacy buckets (model-authored vocabulary), unchanged.
const directlyVerified = classificationsList.filter((c: any) => c.classification === 'source_confirmed' || c.classification === 'verified_fact');
const creatorClaims = classificationsList.filter((c: any) => c.classification === 'creator_claim');
const inferences = classificationsList.filter((c: any) => c.classification === 'inference');
const unknownClaims = classificationsList.filter((c: any) => c.classification === 'unknown');
const runtimeObservations = classificationsList.filter((c: any) => c.classification === 'runtime_observed');
---

<Layout 
  title={`${article.headline} - JuryPress`}
  description={article.meta_description}
  ogImage={`/og/${review.slug}.svg`}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
  isArticlePage={true}
>
  <div class="article-layout">
    <!-- Breadcrumbs -->
    <Breadcrumbs items={[{ label: product.name }]} />

    <!-- Article Hero Section -->
    <header class="article-hero">
      <div class="hero-left">
        <div class="article-meta-tags">
          <span class="meta-tag category">{product.category}</span>
          <span class="meta-tag source">{selection.source}</span>
          <span class="meta-tag date tabular-nums">{new Date(review.published_at).toISOString().split('T')[0]}</span>
        </div>
        
        <h1 class="article-headline">{article.headline}</h1>
        <p class="article-standfirst">{article.standfirst}</p>
        
        <!-- Compact Rank Strip -->
        {review.ranking_eligible ? (
          <div class="rank-strip">
            <span class="rank-item">Overall <strong>#{overallRank}</strong></span>
            <span class="rank-divider">|</span>
            <span class="rank-item">{monthStr} <strong>#{monthlyRank}</strong></span>
            {judgeNames.map(j => (
              <>
                <span class="rank-divider">|</span>
                <a href={withBase(`/rankings/judges/${j}/`)} class="rank-link-badge">
                  {j.charAt(0).toUpperCase() + j.slice(1)} <strong>#{judgeRanks[j]}</strong>
                </a>
              </>
            ))}
          </div>
        ) : (
          <div class="rank-strip">
            {(review as any).evaluation_status === 'evidence_limited' ? (
              <span class="rank-item font-bold text-ink-muted">Unranked — Insufficient evidence for a complete assessment</span>
            ) : (
              <span class="rank-item font-bold text-ink-muted">Unranked — Related-party review</span>
            )}
          </div>
        )}
      </div>
      
      <div class="hero-right">
        <VerdictPlate
          juryScore={review.jury_score}
          judgeRange={review.judge_score_range}
          evidenceConfidence={review.evaluation.overall_evidence_confidence || 0}
          isFixture={isFixtureMode}
        />
      </div>
    </header>

    <!-- Translucent, restrained notice bar about automation and editorial provenance (§13). -->
    <div class="automation-notice-card">
      <span class="notice-icon">{review.editorial_provenance === 'ai_generated_human_edited' ? '✍️' : '🤖'}</span>
      <p class="notice-text">
        {review.editorial_provenance === 'ai_generated_human_edited' ? (
          "AI-generated, human-edited. The jury evaluation, scores, and initial article text were generated automatically; a human then edited the article text before publication. The jury scores and criterion scores were not changed by a human, and this revision passed the same quality checks as an autonomously published one."
        ) : selection.selection_mode === 'initial-bootstrap' ? (
          "Autonomously generated. This product was included in JuryPress's initial launch set by the operator. The jury evaluation, scores, and article text were generated automatically. No human edited the jury scores or verdict before first publication."
        ) : selection.selection_mode === 'reader-request' ? (
          <>
            Autonomously generated. Reader requested — this product was submitted through a public review request and approved for evaluation by the operator. It passed the same Eligibility Gate as every daily selection, and the jury evaluation, scores, article text, and publication were generated automatically with no score adjustment for being requested.
            {selection.request_provenance?.issue_url && (
              <> <a href={selection.request_provenance.issue_url} target="_blank" rel="noopener">View the original request →</a></>
            )}
          </>
        ) : (
          "Autonomously generated. This product was selected by the automated daily curation process. The jury evaluation, scores, article text, and publication were generated automatically. No human edited the jury scores or verdict before first publication."
        )}
      </p>
    </div>

    {review.disclosure && (
      <div class="disclosure-card">
        <span class="disclosure-icon">ℹ️</span>
        <p class="disclosure-text">
          {review.disclosure}
        </p>
      </div>
    )}

    <!-- Selection Details (Initially Folded) -->
    <details class="selection-details">
      <summary class="selection-summary">
        <span class="summary-label">Selection and product details</span>
        <span class="summary-quick-meta">
          Source: <strong>{
            selection.source === 'github' ? 'GitHub' :
            selection.source === 'hacker-news' ? 'Hacker News' :
            selection.source === 'hugging-face' ? 'Hugging Face' :
            selection.source === 'reader_request' ? 'Reader request' :
            selection.source
          }</strong> ·
          {selection.source_metrics && selection.source_metrics.length > 0 && (
            <span>
              Source snapshot: {selection.source_metrics.map((m: any, idx: number) => {
                const formattedPlatform = m.platform === 'github' ? 'GitHub' : m.platform === 'hacker-news' ? 'Hacker News' : m.platform === 'hugging-face' ? 'Hugging Face' : m.platform;
                const formattedUnit = m.platform === 'github' ? 'stars' : m.platform === 'hacker-news' ? 'points' : m.platform === 'hugging-face' ? 'likes' : m.metric;
                const retrievedDate = new Date(m.retrieved_at);
                const formattedDate = retrievedDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                return (
                  <span>
                    {idx > 0 ? ' · ' : ''}
                    {formattedPlatform}: {m.value} {formattedUnit} (Retrieved {formattedDate})
                  </span>
                );
              })} · 
            </span>
          )}
          Website: <a href={selection.canonical_url} target="_blank" rel="noopener" class="summary-url-link">{selection.canonical_url}</a>
        </span>
      </summary>
      <div class="selection-expand-content">
        <div class="details-grid">
          <div class="details-col">
            <h4>Curation Metrics</h4>
            <ul>
              {selection.selection_mode === 'initial-bootstrap' ? (
                <>
                  <li><strong>Selection Mode:</strong> Initial launch set</li>
                  <li><strong>Selected by:</strong> Operator</li>
                </>
              ) : selection.selection_mode === 'reader-request' ? (
                <>
                  <li><strong>Selection Mode:</strong> Reader requested (operator-approved)</li>
                  <li><strong>Selected by:</strong> Operator</li>
                  {selection.request_provenance?.issue_url && (
                    <li>
                      <strong>Request:</strong>{' '}
                      <a href={selection.request_provenance.issue_url} target="_blank" rel="noopener">
                        GitHub Issue #{selection.request_provenance.issue_number}
                      </a>
                    </li>
                  )}
                </>
              ) : (
                <>
                  <li><strong>Selection Mode:</strong> Automated daily curation</li>
                  <li><strong>Selected by:</strong> System</li>
                  <li><strong>Source Rank:</strong> {selection.source_rank}</li>
                </>
              )}
            </ul>
          </div>
          <div class="details-col">
            <h4>Product Overview</h4>
            <ul>
              <li><strong>Audience:</strong> {product.primary_audience}</li>
              <li><strong>Category:</strong> {product.category}</li>
              <li><strong>Website:</strong> <a href={selection.canonical_url} target="_blank" rel="noopener">{selection.canonical_url}</a></li>
            </ul>
          </div>
        </div>
        <div class="product-summary-block">
          <h4>Product Summary</h4>
          <p>{product.summary}</p>
        </div>
      </div>
    </details>

    <hr class="article-divider" />

    <!-- Editorial Lead: Jury Summary (Narrow width) -->
    <section class="reading-section jury-summary-section">
      <h2 class="section-title">Jury Summary</h2>
      <p class="jury-summary-text">{article.jury_summary}</p>
    </section>

    <!-- Agreements and Disagreements (Split 2-Columns) -->
    <section class="jury-breakdown-section">
      <div class="breakdown-grid">
        <div class="breakdown-col agreed">
          <h3 class="breakdown-title title-agreed">WHERE THE JURY AGREED</h3>
          <ul class="breakdown-list">
            {article.where_jury_agreed.map((point: string) => (
              <li>
                <span class="point-marker check">✓</span>
                <p>{point}</p>
              </li>
            ))}
          </ul>
        </div>
        
        <div class="breakdown-col split">
          <h3 class="breakdown-title title-split">WHERE THE JURY SPLIT</h3>
          <ul class="breakdown-list">
            {article.where_jury_disagreed.map((point: any) => (
              <li>
                <span class="criterion-pill">{point.criterion_id.replace(/_/g, ' ')}</span>
                <p>{point.summary}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Ad Slot (Future Insertion Place) -->
    <AdSense slotId={import.meta.env.PUBLIC_ADSENSE_SLOT_ARTICLE_1} />

    <!-- Detailed scorecards -->
    <section class="judges-scorecards-section">
      <h2 class="scorecards-heading">Five Jury Perspectives</h2>
      <p class="scorecards-subheading">
        Five simulated professional perspectives scored the same public evidence using the JuryPress Open Product Rubric.
      </p>
      
      <div class="scorecards-stack">
        {judges.map((judge: any) => (
          <Scorecard judge={judge} />
        ))}
      </div>
    </section>

    <!-- Final Verdict -->
    <section class="reading-section final-verdict-section">
      <h2 class="verdict-heading">Final Verdict</h2>
      <p class="verdict-body-text">{article.final_verdict}</p>
    </section>

    <!-- Judgie-AI CTA -->
    <section class="reading-section cta-section">
      <div class="judgie-cta-box">
        <h3>Bring the jury to your own project</h3>
        <p>Run the same five AI personas with your own evidence and evaluation criteria using Judgie-AI.</p>
        <a href={withUtm(brands.judgie.url, `article_judgie_${review.slug}`)} class="btn-primary" target="_blank" rel="noopener">
          Explore Judgie-AI →
        </a>
      </div>
    </section>

    <AdSense slotId={import.meta.env.PUBLIC_ADSENSE_SLOT_ARTICLE_2} />

    {review.corrections && review.corrections.length > 0 && (
      <section class="corrections-section">
        <h2 class="section-title">Corrections & Updates</h2>
        <div class="corrections-list-container">
          {review.corrections.map((corr: any) => {
            const corrDate = new Date(corr.corrected_at);
            const formattedCorrDate = corrDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            return (
              <div class="correction-card">
                <div class="correction-meta">
                  <span class="correction-badge">Correction</span>
                  <span class="correction-date tabular-nums">{formattedCorrDate}</span>
                </div>
                <p class="correction-text">{corr.summary}</p>
                {corr.score_changed && (
                  <div class="correction-score-delta">
                    Jury Score updated: <span class="score-old">{corr.previous_score?.toFixed(1)}</span> → <strong class="score-new">{corr.new_score?.toFixed(1)}</strong>
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Evidence and limitations section (audit-era reviews) -->
    {!isEditorialReview && (
    <section class="evidence-section">
      <h2 class="section-title">Evidence Sources & Limitations</h2>

      <div class="evidence-block">
        <h3>Sources</h3>
        <ul class="sources-list">
          {evidence.map((ev: any) => (
            <li>
              <strong>{ev.evidence_id}</strong>: <a href={ev.url} target="_blank" rel="noopener">{ev.title}</a> ({ev.type})
              <span class="retrieved-time tabular-nums">Retrieved: {ev.retrieved_at}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="evidence-block">
        <h3>Classifications</h3>

        {isRefinedEvaluation ? (
          <Fragment>
            {refinedConfirmedFacts.length > 0 && <h4>Confirmed in supplied source</h4>}
            <ul class="classifications-list">
              {refinedConfirmedFacts.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge verified">Confirmed</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>

            {refinedRepositoryObservations.length > 0 && <h4>Observed in source</h4>}
            <ul class="classifications-list">
              {refinedRepositoryObservations.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge verified">Observed</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>

            {refinedRuntimeObserved.length > 0 && <h4>Directly observed during review</h4>}
            <ul class="classifications-list">
              {refinedRuntimeObserved.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge verified">Observed</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>

            {refinedCreatorClaims.length > 0 && <h4>Creator Claims</h4>}
            <ul class="classifications-list">
              {refinedCreatorClaims.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge claim">Claim</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>

            {refinedCommunityOpinions.length > 0 && <h4>Community Discussion</h4>}
            <ul class="classifications-list">
              {refinedCommunityOpinions.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge community">Community</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>

            {refinedInferences.length > 0 && <h4>Jury Inferences</h4>}
            <ul class="classifications-list">
              {refinedInferences.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge inference">Inference</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>

            {refinedUnverified.length > 0 && <h4>Could not verify</h4>}
            <ul class="classifications-list">
              {refinedUnverified.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge unassessed">Unverified</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>

            {statementProvenanceGroups.length > 0 && <h4>Statement Provenance</h4>}
            {statementProvenanceGroups.length > 0 && (
              <ul class="classifications-list">
                {statementProvenanceGroups.map(group => (
                  <li>
                    <span class={`class-badge ${group.support_mode === 'evidence_backed' ? 'verified' : group.support_mode === 'inference' ? 'inference' : 'unassessed'}`}>
                      {supportModeLabel(group.support_mode)}
                    </span>
                    {sourceProvenanceLabel(group.source_fact_classes)} — {group.statement_count} statement{group.statement_count === 1 ? '' : 's'}
                  </li>
                ))}
              </ul>
            )}
          </Fragment>
        ) : (
          <Fragment>
            {directlyVerified.length > 0 && <h4>Confirmed in supplied source</h4>}
            <ul class="classifications-list">
              {directlyVerified.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge verified">Confirmed</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>

            {creatorClaims.length > 0 && <h4>Creator Claims</h4>}
            <ul class="classifications-list">
              {creatorClaims.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge claim">Claim</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>

            {inferences.length > 0 && <h4>Jury Inferences</h4>}
            <ul class="classifications-list">
              {inferences.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge inference">Inference</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>

            {runtimeObservations.length > 0 && <h4>Directly Observed During Review</h4>}
            <ul class="classifications-list">
              {runtimeObservations.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge verified">Observed</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>

            {unknownClaims.length > 0 && <h4>Could Not Assess / Unknown</h4>}
            <ul class="classifications-list">
              {unknownClaims.map((c: any) => {
                 const ev = evidence.find((e: any) => e.evidence_id === c.evidence_id);
                 return (
                   <li>
                     <span class="class-badge unassessed">Unknown</span>
                     <strong><a href={ev?.url} target="_blank" rel="noopener">{c.evidence_id}</a>:</strong> {c.claim}
                   </li>
                 );
              })}
            </ul>
          </Fragment>
        )}
      </div>

      <div class="evidence-block">
        <h3>Limitations</h3>
        <ul class="limitations-list">
          {(article.evidence_limitations || []).map((lim: string) => <li>{lim}</li>)}
        </ul>
      </div>
    </section>
    )}

    {/*
      Editorial appendix. Collapsed by default and placed after the article: the review is
      the product, and this is the record of how it was made. "Evidence mapping unavailable"
      is a normal, honest state — the article publishes whether or not the map exists.
    */}
    {isEditorialReview && (
    <details class="editorial-appendix">
      <summary>Sources, evidence map and generation metadata</summary>

      <div class="evidence-block">
        <h3>Sources</h3>
        <ul class="sources-list">
          {evidence.map((ev: any) => (
            <li>
              <strong>{ev.evidence_id}</strong>: <a href={ev.url} target="_blank" rel="noopener">{ev.title}</a> ({ev.type})
              <span class="retrieved-time tabular-nums">Retrieved: {ev.retrieved_at}</span>
            </li>
          ))}
        </ul>
      </div>

      {(article.evidence_limitations || []).length > 0 && (
        <div class="evidence-block">
          <h3>What the jury could not assess</h3>
          <ul class="limitations-list">
            {(article.evidence_limitations || []).map((lim: string) => <li>{lim}</li>)}
          </ul>
        </div>
      )}

      <div class="evidence-block">
        <h3>How claims relate to sources</h3>
        {evidenceMap ? (
          <Fragment>
            <p class="appendix-note">
              After this review was written, a separate pass recorded how its statements relate
              to the collected material. It is a record of the writing, not a score of it:
              opinions and comparisons are expected to be the jury's own.
            </p>
            <p class="appendix-note">
              This record covers the review's narrative — the summary, headline, standfirst,
              jury summary, points of agreement and disagreement, stated limitations, verdict,
              and each judge's verdict and leading concern — plus any specific factual claim
              made elsewhere, such as a figure, a security or runtime assertion, or a claim
              about what the project lacks. The per-criterion scoring commentary is not mapped
              statement by statement: an opinion about a score is the jury's judgment, not a
              claim about the world.
              {mapScope
                ? (isPartialMap
                    ? ` ${mappedStatementCount} of ${mapScope.selected_statement_count} covered statements were recorded; the rest are listed below as unrecorded.`
                    : ` All ${mappedStatementCount} covered statements were recorded.`)
                : ` ${mappedStatementCount} statements were recorded. This review predates coverage reporting, so how many were in scope is not known for it.`}
            </p>
            <ul class="classifications-list">
              {claimClassificationRows.map(row => (
                <li>
                  <span class={`class-badge ${row.badge}`}>{row.label}</span>
                  {row.count} statement{row.count === 1 ? '' : 's'}
                </li>
              ))}
            </ul>
            {isPartialMap && evidenceMap.unmapped_statements.length > 0 && (
              <Fragment>
                <h4>Statements with no record</h4>
                <p class="appendix-note">
                  These are in scope but the record pass did not classify them. They are shown
                  so the breakdown above is not mistaken for complete coverage.
                </p>
                <ul class="limitations-list">
                  {evidenceMap.unmapped_statements.map(entry => (
                    <li>“{entry.statement_text}”</li>
                  ))}
                </ul>
              </Fragment>
            )}
            {evidenceMap.contradictions.length > 0 && (
              <Fragment>
                <h4>Statements the evidence appears to contradict</h4>
                <ul class="limitations-list">
                  {evidenceMap.claims
                    .filter(claim => claim.classification === 'contradicted_by_evidence')
                    .map(claim => (
                      <li>
                        “{claim.statement_text}”
                        {claim.note && <span class="appendix-note"> — {claim.note}</span>}
                      </li>
                    ))}
                </ul>
              </Fragment>
            )}
          </Fragment>
        ) : (
          <p class="appendix-note">Evidence mapping unavailable for this review.</p>
        )}
      </div>

      <div class="evidence-block">
        <h3>Generation metadata</h3>
        <ul class="limitations-list">
          <li>Model: {review.generation_metadata?.used_model ?? review.model}</li>
          <li>Prompt version: {review.prompt_version}</li>
          <li>Rubric: {review.rubric_id} {review.rubric_version}</li>
          <li>Scores recalculated by code: {review.provenance?.recalculated_by_code ? 'yes' : 'no'}</li>
          <li>Editorial provenance: {review.editorial_provenance === 'ai_generated_human_edited' ? 'AI generated, human edited' : 'Autonomously generated'}</li>
          <li>Evidence record: {!evidenceMap
            ? 'unavailable'
            : mapScope
              ? `${isPartialMap ? 'partial' : 'complete'} — ${mappedStatementCount}/${mapScope.selected_statement_count} covered statements (${mapScope.excluded_statement_count} scoring statements out of scope)`
              : `${mappedStatementCount} statements recorded (predates coverage reporting)`}</li>
        </ul>
      </div>
    </details>
    )}

    <ReviewDiscussion slug={review.slug} />
  </div>
</Layout>

