---
import Layout from '../../layouts/Layout.astro';
import RubricCard from '../../components/RubricCard.astro';
import { getRubric } from '../../lib/jury';
import { withBase } from '../../lib/base';
import { brands } from '../../config/brands';
import { withUtm } from '../../lib/url';

// Fetch Legacy Season 1 Rubric
const rubric = getRubric("hackathon");
const maxWeight = Math.max(...rubric.map(c => c.weight));
---

<Layout
  title="The Legacy Season 1 Rubric | JuryPress"
  description="The Judgie-AI Hackathon Evaluation rubric used during JuryPress Season 1."
>
  <div class="rubric-page-layout">
    <header class="rubric-hero">
      <h1 class="hero-title">Legacy Season 1 Rubric</h1>
      <p class="hero-subtext">
        Judgie-AI Hackathon Evaluation (Season 1)
      </p>
    </header>

    <aside class="rubric-disclaimer-card" aria-label="Important Note">
      <div class="disclaimer-header">
        <span class="disclaimer-icon">⚠️</span>
        <strong>Legacy Rubric</strong>
      </div>
      <p>
        This page documents the Judgie-AI Hackathon Evaluation rubric used in Season 1.
        It is no longer used for current reviews.
      </p>
      <p>
        For current reviews of open-source software, please check the <a href={withBase('/rubric/')}>Current Rubric (v2)</a>.
      </p>
    </aside>

    <!-- Horizontal Weight Bars -->
    <section class="rubric-section">
      <h2 class="section-title">Weight Overview</h2>
      <div class="weight-bars-box">
        {rubric.map(c => (
          <div class="weight-bar-row">
            <span class="weight-bar-label">{c.name.replace(/_/g, ' ')}</span>
            <div class="weight-bar-track-outer">
              <div
                class="weight-bar-fill-inner"
                style={`width: ${(c.weight / maxWeight) * 100}%`}
                role="img"
                aria-label={`${c.name}: ${c.weight}%`}
              >
                <span class="weight-bar-val tabular-nums">{c.weight}%</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Detailed Criteria Cards -->
    <section class="rubric-section">
      <h2 class="section-title">Criteria Details</h2>
      <div class="criteria-cards-grid">
        {rubric.map(c => (
          <RubricCard criterion={c} />
        ))}
      </div>
    </section>

    <div class="rubric-ctas-grid">
      <a href={withBase('/rubric/')} class="cta-link-btn">
        View Current Rubric (v2) →
      </a>
    </div>
  </div>
</Layout>

<style>
  .rubric-page-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .rubric-hero {
    text-align: center;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: var(--space-8);
    margin-top: var(--space-4);
  }

  .hero-title {
    font-family: var(--font-editorial);
    font-size: 2.75rem;
    font-weight: 800;
    color: var(--color-ink);
    margin-bottom: var(--space-2);
  }

  .hero-subtext {
    font-family: var(--font-interface);
    font-size: 1.1rem;
    color: var(--color-ink-muted);
    font-weight: 600;
  }

  /* Disclaimer Box */
  .rubric-disclaimer-card {
    background: var(--color-surface);
    border: 1px solid var(--color-rule-strong);
    border-left: 4px solid var(--color-ink-muted);
    padding: var(--space-6);
    border-radius: var(--radius-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .disclaimer-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-interface);
    font-size: 0.95rem;
    color: var(--color-ink);
  }

  .rubric-disclaimer-card p {
    font-family: var(--font-interface);
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    line-height: 1.5;
    margin: 0;
  }

  .rubric-disclaimer-card a {
    color: var(--color-ink);
    text-decoration: underline;
  }

  .rubric-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .section-title {
    font-family: var(--font-editorial);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-ink);
    border-bottom: 2px solid var(--color-ink);
    padding-bottom: var(--space-2);
  }

  /* Weight overview bars */
  .weight-bars-box {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    padding: var(--space-6);
    border-radius: var(--radius-sm);
  }

  .weight-bar-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .weight-bar-label {
    flex: 0 0 200px;
    font-family: var(--font-interface);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-ink);
    text-transform: capitalize;
    text-align: right;
  }

  .weight-bar-track-outer {
    flex: 1;
    background: var(--color-canvas);
    border-radius: var(--radius-sm);
    height: 1.75rem;
    overflow: hidden;
  }

  .weight-bar-fill-inner {
    background: var(--color-accent);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: var(--space-3);
    min-width: 2.5rem;
  }

  .weight-bar-val {
    color: var(--color-canvas);
    font-weight: 700;
    font-size: 0.85rem;
  }

  /* Criteria Cards Grid */
  .criteria-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: var(--space-6);
  }

  /* CTAs */
  .rubric-ctas-grid {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-4);
  }

  .cta-link-btn {
    background: var(--color-ink);
    color: var(--color-canvas);
    font-family: var(--font-interface);
    font-weight: 700;
    font-size: 0.95rem;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .cta-link-btn:hover {
    background: var(--color-accent);
  }

  @media (max-width: 600px) {
    .weight-bar-row {
      flex-direction: column;
      align-items: stretch;
      gap: 4px;
    }
    
    .weight-bar-label {
      text-align: left;
      flex: none;
    }

    .criteria-cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
