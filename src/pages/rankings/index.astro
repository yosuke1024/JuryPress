---
import Layout from '../../layouts/Layout.astro';
import { getAllReviews, sortReviews } from '../../lib/data';
import { withBase } from '../../lib/base';

// Overall Ranking Logic
const reviews = sortReviews(getAllReviews());

---

<Layout title="Overall Ranking | JuryPress">
  <h1>Overall Ranking</h1>
  <p>All products evaluated by JuryPress, ranked deterministically.</p>

  <table class="ranking-table">
    <thead>
      <tr>
        <th>Rank</th>
        <th>Product</th>
        <th>Jury Score</th>
        <th>Judge Range</th>
        <th>Published</th>
      </tr>
    </thead>
    <tbody>
      {reviews.map((r, index) => (
        <tr>
          <td>{index + 1}</td>
          <td><a href={withBase(`/reviews/${r.slug}`)}>{r.review.evaluation.product.name}</a></td>
          <td><strong>{r.review.jury_score.toFixed(1)}</strong></td>
          <td>{r.review.judge_score_range.min.toFixed(1)} - {r.review.judge_score_range.max.toFixed(1)}</td>
          <td>{new Date(r.review.published_at).toISOString().split('T')[0]}</td>
        </tr>
      ))}
    </tbody>
  </table>
</Layout>

<style>
  .ranking-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 2rem;
  }
  .ranking-table th, .ranking-table td {
    padding: 1rem;
    border-bottom: 1px solid #ddd;
    text-align: left;
  }
  .ranking-table th {
    background: #f4f4f4;
  }
</style>
