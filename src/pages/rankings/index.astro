---
import Layout from '../../layouts/Layout.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import VerdictPlate from '../../components/VerdictPlate.astro';
import { getAllReviews, sortReviews } from '../../lib/data';
import { withBase } from '../../lib/base';

const allReviews = getAllReviews();
// Sort by jury score (Season 2 only)
const reviews = sortReviews(allReviews.filter(r => 
  r.review.season === 2 && 
  r.review.ranking_eligible === true && 
  (r.review as any).evaluation_status === 'complete'
));
const relatedReviews = allReviews.filter(r => r.review.season === 2 && r.review.ranking_eligible === false);
const legacyReviews = allReviews.filter(r => r.review.season === 1);

// Consensus helper for table
function getConsensus(min: number, max: number) {
  const diff = max - min;
  if (diff <= 5.0) return { label: 'Consensus', cls: 'consensus-strong' };
  if (diff <= 12.0) return { label: 'Agreement', cls: 'consensus-general' };
  if (diff <= 20.0) return { label: 'Split', cls: 'consensus-split' };
  return { label: 'Divisive', cls: 'consensus-divisive' };
}

const showTopThree = reviews.length >= 3;
const topThree = showTopThree ? reviews.slice(0, 3) : [];
const tableReviews = showTopThree ? reviews.slice(3) : [];
---

<Layout title="Overall Rankings | JuryPress">
  <div class="rankings-page">
    <header class="rankings-header">
      <h1 class="page-title">Product Rankings</h1>
      <p class="page-subtext">All eligible open-source software products, ranked deterministically by Jury Score.</p>
      
      <div class="rankings-isolation-notice" style="margin-top: var(--space-4); font-size: 0.9rem; color: var(--color-ink-muted);">
        <p>
          Current rankings use the JuryPress Open Product Rubric v2 and include only
          eligible open-source software products with complete evidence coverage.
          Legacy Season 1 scores are not included.
        </p>
      </div>

      {relatedReviews.length > 0 && (
        <p class="related-party-note">
          {relatedReviews.length} related-party review{relatedReviews.length > 1 ? 's are' : ' is'} published but excluded from rankings.
          Read the verdicts for {relatedReviews.map((r, i) => (
            <span>
              {i > 0 && ' and '}
              <a href={withBase(`/reviews/${r.slug}/`)}>{r.review.evaluation.product.name}</a>
            </span>
          ))}.
        </p>
      )}

      {legacyReviews.length > 0 && (
        <p class="legacy-reviews-note" style="font-family: var(--font-interface); font-size: 0.9rem; color: var(--color-ink-muted); margin-top: var(--space-2);">
          Legacy Season 1 reviews (using the Hackathon Rubric) remain accessible as historical archives.
          Read the Legacy reviews for {legacyReviews.map((r, i) => (
            <span>
              {i > 0 && ', '}
              <a href={withBase(`/reviews/${r.slug}/`)} style="color: var(--color-ink); text-decoration: underline;">{r.review.evaluation.product.name}</a>
            </span>
          ))}.
        </p>
      )}
    </header>

    <!-- Top Rated Display -->
    {showTopThree ? (
      <section class="podium-section">
        <h2 class="visually-hidden">Top Three Products</h2>
        <div class="podium-grid">
          <!-- 2nd Place -->
          <div class="podium-col second-place">
            <span class="podium-rank">2</span>
            <div class="podium-card-wrap">
              <ReviewCard
                slug={topThree[1].slug}
                productName={topThree[1].review.evaluation.product.name}
                headline={topThree[1].review.evaluation.article.headline}
                juryScore={topThree[1].review.jury_score}
                judgeRange={topThree[1].review.judge_score_range}
                publishedAt={topThree[1].review.published_at}
                variant="compact"
              />
            </div>
          </div>
          
          <!-- 1st Place -->
          <div class="podium-col first-place">
            <span class="podium-rank gold">1</span>
            <div class="podium-card-wrap">
              <ReviewCard
                slug={topThree[0].slug}
                productName={topThree[0].review.evaluation.product.name}
                headline={topThree[0].review.evaluation.article.headline}
                juryScore={topThree[0].review.jury_score}
                judgeRange={topThree[0].review.judge_score_range}
                publishedAt={topThree[0].review.published_at}
                variant="large"
              />
            </div>
          </div>

          <!-- 3rd Place -->
          <div class="podium-col third-place">
            <span class="podium-rank">3</span>
            <div class="podium-card-wrap">
              <ReviewCard
                slug={topThree[2].slug}
                productName={topThree[2].review.evaluation.product.name}
                headline={topThree[2].review.evaluation.article.headline}
                juryScore={topThree[2].review.jury_score}
                judgeRange={topThree[2].review.judge_score_range}
                publishedAt={topThree[2].review.published_at}
                variant="compact"
              />
            </div>
          </div>
        </div>
      </section>
    ) : (
      /* If only 1 or 2 products exist, show simple cards horizontally/vertically without Podium */
      <section class="simple-cards-section">
        <div class="simple-cards-grid">
          {reviews.map((r, index) => (
            <div class="single-rank-card-container">
              <div class="card-rank-badge tabular-nums">#{index + 1}</div>
              <ReviewCard
                slug={r.slug}
                productName={r.review.evaluation.product.name}
                headline={r.review.evaluation.article.headline}
                juryScore={r.review.jury_score}
                judgeRange={r.review.judge_score_range}
                publishedAt={r.review.published_at}
                variant={reviews.length === 1 ? "large" : "compact"}
              />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Rankings Table (Remaining Products) -->
    {((showTopThree && tableReviews.length > 0) || (!showTopThree && reviews.length > 2)) && (
      <section class="table-section">
        <h2 class="section-subtitle">Rankings Ledger</h2>
        <div class="table-container">
          <table class="ranking-table">
            <thead>
              <tr>
                <th class="rank-col">Rank</th>
                <th>Product</th>
                <th class="text-right">Jury Score</th>
                <th class="hide-mobile">Consensus</th>
                <th class="hide-tablet">Range</th>
                <th class="hide-mobile">Published Date</th>
              </tr>
            </thead>
            <tbody>
              {(showTopThree ? tableReviews : reviews).map((r, index) => {
                const actualRank = showTopThree ? index + 4 : index + 1;
                const consensus = getConsensus(r.review.judge_score_range.min, r.review.judge_score_range.max);
                return (
                  <tr>
                    <td class="rank-col tabular-nums font-bold">#{actualRank}</td>
                    <td class="product-name-col">
                      <a href={withBase(`/reviews/${r.slug}`)} class="table-product-link">
                        {r.review.evaluation.product.name}
                      </a>
                    </td>
                    <td class="text-right tabular-nums font-bold">{r.review.jury_score.toFixed(1)}</td>
                    <td class="hide-mobile">
                      <span class={`consensus-badge ${consensus.cls}`}>{consensus.label}</span>
                    </td>
                    <td class="hide-tablet tabular-nums">
                      {r.review.judge_score_range.min.toFixed(1)}–{r.review.judge_score_range.max.toFixed(1)}
                    </td>
                    <td class="hide-mobile tabular-nums">
                      {new Date(r.review.published_at).toISOString().split('T')[0]}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  .rankings-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .rankings-header {
    text-align: center;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: var(--space-8);
    margin-top: var(--space-4);
  }

  .page-title {
    font-family: var(--font-editorial);
    font-size: 2.75rem;
    font-weight: 800;
    color: var(--color-ink);
    margin-bottom: var(--space-2);
  }

  .page-subtext {
    font-family: var(--font-interface);
    font-size: 1.1rem;
    color: var(--color-ink-muted);
    font-weight: 600;
  }

  /* Podium Display */
  .podium-section {
    margin-top: var(--space-4);
  }

  .podium-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    gap: var(--space-6);
    align-items: flex-end;
  }

  .podium-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .podium-rank {
    font-family: var(--font-editorial);
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-rule-strong);
    text-align: center;
    line-height: 1;
  }

  .podium-rank.gold {
    color: var(--color-accent);
    font-size: 4rem;
  }

  .first-place {
    order: 2;
  }

  .second-place {
    order: 1;
  }

  .third-place {
    order: 3;
  }

  /* Simple Cards Layout */
  .simple-cards-section {
    margin-top: var(--space-4);
  }

  .simple-cards-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .single-rank-card-container {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .card-rank-badge {
    font-family: var(--font-editorial);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-rule-strong);
    width: 60px;
    text-align: center;
  }

  /* Rankings Ledger Table */
  .table-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .section-subtitle {
    font-family: var(--font-editorial);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-ink);
    border-bottom: 2px solid var(--color-ink);
    padding-bottom: var(--space-2);
  }

  .table-container {
    overflow-x: auto;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
  }

  .ranking-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-interface);
    font-size: 0.9rem;
    background: var(--color-surface);
  }

  .ranking-table th, .ranking-table td {
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-canvas);
    text-align: left;
  }

  .ranking-table th {
    background: var(--color-surface-muted);
    font-weight: 700;
    color: var(--color-ink);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
  }

  .ranking-table tr:last-child td {
    border-bottom: none;
  }

  .rank-col {
    width: 80px;
  }

  .table-product-link {
    color: var(--color-ink);
    font-weight: 700;
  }

  .table-product-link:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .text-right {
    text-align: right;
  }

  .font-bold {
    font-weight: 700;
  }

  .consensus-badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .consensus-strong, .consensus-general {
    background: #e8f5e9;
    color: var(--color-positive);
  }

  .consensus-split {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .consensus-divisive {
    background: #fde8e8;
    color: var(--color-critical);
  }

  /* Responsive Design */
  @media (max-width: 900px) {
    .podium-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .first-place, .second-place, .third-place {
      order: unset;
    }

    .podium-rank {
      text-align: left;
      font-size: 2.25rem;
      border-bottom: 1px solid var(--color-rule);
      padding-bottom: var(--space-1);
    }

    .podium-rank.gold {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .hide-tablet {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .hide-mobile {
      display: none;
    }
    
    .ranking-table th, .ranking-table td {
      padding: var(--space-3);
    }
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .related-party-note {
    font-family: var(--font-interface);
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    margin-top: var(--space-4);
  }
  .related-party-note a {
    color: var(--color-accent);
    font-weight: 700;
  }
  .related-party-note a:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }
</style>
