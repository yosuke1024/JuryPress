---
import Layout from '../../layouts/Layout.astro';
import RankingBoard from '../../components/RankingBoard.astro';
import RankingPeriodNav from '../../components/RankingPeriodNav.astro';
import { getAllReviews, sortReviews } from '../../lib/data';
import { getRankedReviews, getLatestPeriodKey, isHistoricalMethodology } from '../../lib/rankings';
import { withBase } from '../../lib/base';

const allReviews = getAllReviews();
// All-time rankings use the same Current Cohort definition as every period page.
const reviews = sortReviews(getRankedReviews(allReviews));
// Base eligibility recorded at generation time (related-party / incomplete evaluation).
// This is the one legitimate direct read of the raw flag: it is asking what the generator
// decided, not whether the review ranks today.
const relatedReviews = allReviews.filter(r => r.review.season === 2 && r.review.ranking_eligible === false);
const historicalReviews = sortReviews(allReviews.filter(isHistoricalMethodology));
const legacyReviews = allReviews.filter(r => r.review.season === 1);

const latest = {
  annual: getLatestPeriodKey('annual', allReviews),
  monthly: getLatestPeriodKey('monthly', allReviews),
  weekly: getLatestPeriodKey('weekly', allReviews)
};
---

<Layout title="Overall Rankings | JuryPress">
  <div class="rankings-page">
    <header class="rankings-header">
      <h1 class="page-title">Product Rankings</h1>
      <p class="page-subtext">All eligible open-source software products, ranked deterministically by Jury Score.</p>

      <div class="rankings-period-nav-wrap">
        <RankingPeriodNav active="all-time" latest={latest} />
      </div>

      <div class="rankings-isolation-notice" style="margin-top: var(--space-4); font-size: 0.9rem; color: var(--color-ink-muted);">
        <p>
          Current rankings use the JuryPress Open Product Rubric v2 and include only
          eligible open-source software products with complete evidence coverage.
          Legacy Season 1 scores are not included.
        </p>
        {historicalReviews.length > 0 && (
          <p>
            {historicalReviews.length} published {historicalReviews.length === 1 ? 'review predates' : 'reviews predate'} the
            current statement-level evidence map and {historicalReviews.length === 1 ? 'is' : 'are'} not ranked.
            {' '}They remain published and readable — see{' '}
            <a href={withBase('/methodology/history/')}>Methodology History</a>.
          </p>
        )}
      </div>

      {relatedReviews.length > 0 && (
        <p class="related-party-note">
          {relatedReviews.length} related-party review{relatedReviews.length > 1 ? 's are' : ' is'} published but excluded from rankings.
          Read the verdicts for {relatedReviews.map((r, i) => (
            <span>
              {i > 0 && ' and '}
              <a href={withBase(`/reviews/${r.slug}/`)}>{r.review.evaluation.product.name}</a>
            </span>
          ))}.
        </p>
      )}

      {legacyReviews.length > 0 && (
        <p class="legacy-reviews-note" style="font-family: var(--font-interface); font-size: 0.9rem; color: var(--color-ink-muted); margin-top: var(--space-2);">
          Legacy Season 1 reviews (using the Hackathon Rubric) remain accessible as historical archives.
          Read the Legacy reviews for {legacyReviews.map((r, i) => (
            <span>
              {i > 0 && ', '}
              <a href={withBase(`/reviews/${r.slug}/`)} style="color: var(--color-ink); text-decoration: underline;">{r.review.evaluation.product.name}</a>
            </span>
          ))}.
        </p>
      )}
    </header>

    <RankingBoard reviews={reviews} />
  </div>
</Layout>

<style>
  .rankings-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .rankings-header {
    text-align: center;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: var(--space-8);
    margin-top: var(--space-4);
  }

  .page-title {
    font-family: var(--font-editorial);
    font-size: 2.75rem;
    font-weight: 800;
    color: var(--color-ink);
    margin-bottom: var(--space-2);
  }

  .page-subtext {
    font-family: var(--font-interface);
    font-size: 1.1rem;
    color: var(--color-ink-muted);
    font-weight: 600;
  }

  .rankings-period-nav-wrap {
    margin-top: var(--space-6);
  }

  .related-party-note {
    font-family: var(--font-interface);
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    margin-top: var(--space-4);
  }
  .related-party-note a {
    color: var(--color-accent);
    font-weight: 700;
  }
  .related-party-note a:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }
</style>
