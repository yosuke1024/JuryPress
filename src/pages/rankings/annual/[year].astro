---
import PeriodRankingPage from '../../../components/PeriodRankingPage.astro';
import { getAllReviews } from '../../../lib/data';
import { listPeriodKeys } from '../../../lib/rankings';

// Only periods that actually contain Current Cohort reviews get a page.
export function getStaticPaths() {
  return listPeriodKeys('annual', getAllReviews()).map(year => ({ params: { year } }));
}

const { year } = Astro.params;
---

<PeriodRankingPage kind="annual" periodKey={year!} />
