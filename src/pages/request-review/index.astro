---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/base';
import { REVIEW_REQUEST_NEW_ISSUE_URL } from '../../config/review-requests';
---

<Layout
  title="Request a Review | JuryPress"
  description="Ask the five-person AI jury to review an open-source product. Requests are public GitHub Issues submitted with your own GitHub account and go through the same eligibility gate and rubric as daily selections."
>
  <div class="request-page">
    <header class="request-header">
      <div class="header-eyebrow">REQUEST A REVIEW</div>
      <h1 class="header-title">Ask the jury to review an open-source product.</h1>
      <p class="header-desc">
        Know an open-source product the five-person AI jury should evaluate? Submit a
        request as a <strong>public GitHub Issue</strong> using your own GitHub account.
        The issue becomes the single source of truth for your request: progress and the
        final result are posted there.
      </p>
    </header>

    <div class="request-cta-box">
      <a class="request-cta-button" href={REVIEW_REQUEST_NEW_ISSUE_URL} target="_blank" rel="noopener">
        Request a review on GitHub →
      </a>
      <p class="request-cta-note">Requires a GitHub account. Opens the Review Request issue form.</p>
    </div>

    <section class="request-section">
      <h2>What you'll need</h2>
      <ul>
        <li><strong>Product name</strong> — the product's official name.</li>
        <li><strong>Canonical public repository URL</strong> — a public GitHub repository (<code>https://github.com/owner/project</code>) or Hugging Face Space (<code>https://huggingface.co/spaces/owner/space</code>). https only.</li>
        <li><strong>One-sentence purpose</strong> — what the product does (20–500 characters).</li>
        <li><strong>Your relationship to the product</strong> — Creator/Maintainer, Contributor, User, or Other.</li>
        <li>Optionally: an official website / demo URL and up to 5 additional official documentation URLs.</li>
      </ul>
    </section>

    <section class="request-section">
      <h2>How requests are handled</h2>
      <ol>
        <li>Your issue is created with the <code>review-request</code> label and waits for the operator.</li>
        <li>An operator starts the evaluation explicitly. The product is checked against the <a href={withBase('/methodology/')}>same Eligibility Gate</a> as every automated daily selection.</li>
        <li>If eligible, official evidence is collected and the five-person jury evaluates it under the standard rubric. The text of your issue is never used as evaluation evidence, and being requested has no effect on the Jury Score.</li>
        <li>The result — a published review, or a decline with its reason — is posted on your issue, and the issue is closed.</li>
      </ol>
      <p class="request-disclaimer">
        Submitting a request guarantees neither publication nor a favorable score. Please
        don't include personal or confidential information — the issue is public.
      </p>
    </section>
  </div>
</Layout>

<style>
  .request-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 1rem 0 3rem;
  }

  .header-eyebrow {
    font-family: var(--font-interface);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-accent, #c67c3b);
    margin-bottom: var(--space-2, 0.5rem);
  }

  .header-title {
    font-size: 2rem;
    color: var(--color-ink, #1a1a2e);
    margin-bottom: var(--space-3, 0.75rem);
    font-weight: 800;
    line-height: 1.15;
  }

  .header-desc {
    font-family: var(--font-interface);
    font-size: 0.98rem;
    color: var(--color-ink-muted, #555);
    line-height: 1.6;
    margin-bottom: var(--space-6, 1.5rem);
  }

  .request-cta-box {
    margin: 1.5rem 0 2rem;
  }

  .request-cta-button {
    display: inline-block;
    font-family: var(--font-interface);
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    background: var(--color-accent, #c67c3b);
    border-radius: var(--radius-sm, 4px);
    padding: 0.8rem 1.8rem;
    text-decoration: none;
  }

  .request-cta-button:hover { filter: brightness(0.95); }

  .request-cta-note {
    font-family: var(--font-interface);
    font-size: 0.85rem;
    color: var(--color-ink-muted, #777);
    margin-top: 0.5rem;
  }

  .request-section {
    margin-bottom: 1.8rem;
  }

  .request-section h2 {
    font-size: 1.2rem;
    color: var(--color-ink, #1a1a2e);
    border-bottom: 1px solid #eee;
    margin-bottom: 0.6rem;
    padding-bottom: 0.4rem;
  }

  .request-section ul,
  .request-section ol {
    font-family: var(--font-interface);
    font-size: 0.93rem;
    color: var(--color-ink, #444);
    padding-left: 1.3rem;
    line-height: 1.6;
  }

  .request-section li {
    margin-bottom: 0.4rem;
    overflow-wrap: anywhere;
  }

  .request-section a {
    color: var(--color-accent, #c67c3b);
    font-weight: 600;
    text-decoration: none;
  }

  .request-section a:hover { text-decoration: underline; }

  .request-disclaimer {
    font-family: var(--font-interface);
    font-size: 0.9rem;
    color: var(--color-ink-muted, #555);
    background: var(--color-surface-muted, #f6f4ef);
    border-left: 4px solid var(--color-accent, #c67c3b);
    padding: 0.8rem 1rem;
    margin-top: 1rem;
    line-height: 1.6;
  }

  @media (max-width: 480px) {
    .header-title { font-size: 1.55rem; }
    .request-cta-button {
      display: block;
      text-align: center;
    }
  }
</style>
