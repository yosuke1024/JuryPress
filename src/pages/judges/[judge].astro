---
import Layout from '../../layouts/Layout.astro';
import JudgeAvatar from '../../components/JudgeAvatar.astro';
import { getJudges, getRubric } from '../../lib/jury';
import { getAllReviews, sortReviews } from '../../lib/data';
import { withBase } from '../../lib/base';
import { brands } from '../../config/brands';
import { withUtm } from '../../lib/url';
import type { JudgeProfile } from '../../schemas/jury';

export function getStaticPaths() {
  const judges = getJudges();
  return judges.map(j => ({
    params: { judge: j.slug },
    props: { judgeProfile: j },
  }));
}

interface Props {
  judgeProfile: JudgeProfile;
}

const { judgeProfile } = Astro.props;
const { judge: judgeSlug } = Astro.params;

// Recent verdicts (latest 3)
const allReviews = getAllReviews();
const recentReviews = [...allReviews]
  .sort((a, b) => new Date(b.review.published_at).getTime() - new Date(a.review.published_at).getTime())
  .slice(0, 3)
  .map(r => {
    const judgeData = r.review.evaluation.judges.find((j: any) => j.judge_id === judgeSlug);
    return {
      slug: r.slug,
      productName: r.review.evaluation.product.name,
      judgeScore: judgeData?.judge_score || 0,
      juryAverage: r.review.jury_score,
      difference: (judgeData?.judge_score || 0) - r.review.jury_score,
      verdict: judgeData?.verdict || '',
      publishedAt: r.review.published_at,
    };
  });

// Ranking preview (top 5 by this judge)
const rankedReviews = allReviews
  .filter(r => r.review.ranking_eligible === true)
  .sort((a, b) => {
    const scoreA = a.review.evaluation.judges.find((j: any) => j.judge_id === judgeSlug)?.judge_score || 0;
    const scoreB = b.review.evaluation.judges.find((j: any) => j.judge_id === judgeSlug)?.judge_score || 0;
    return scoreB - scoreA;
  })
  .slice(0, 5);
---

<Layout
  title={`${judgeProfile.name} — ${judgeProfile.role} AI Judge | JuryPress`}
  description={`${judgeProfile.name} is a Judgie-AI persona who evaluates products as a ${judgeProfile.role}. Learn about their evaluation approach.`}
>
  <div class="judge-profile-layout">
    <!-- Hero Header -->
    <header class="profile-hero">
      <div class="hero-avatar-wrap">
        <JudgeAvatar name={judgeProfile.name} role={judgeProfile.role} slug={judgeProfile.slug} size={110} />
      </div>
      
      <div class="hero-info">
        <span class="persona-badge">Fictional AI Evaluation Persona</span>
        <h1 class="profile-title">{judgeProfile.name}</h1>
        <p class="profile-role">{judgeProfile.role}</p>
        
        <p class="persona-provenance">
          Defined and maintained in 
          <a href={withUtm(brands.judgie.url, `judge_profile_judgie`)} target="_blank" rel="noopener">{brands.judgie.name}</a>.
        </p>
      </div>

      <div class="profile-lead-statement">
        <p class="personality-text">“{judgeProfile.personalityAndTone}”</p>
      </div>
    </header>

    <div class="profile-body-grid">
      <!-- Left Column: Biography and Focus -->
      <div class="body-col-main">
        <section class="profile-section">
          <h2 class="section-title">Background</h2>
          <p class="section-text">{judgeProfile.background}</p>
        </section>

        <section class="profile-section">
          <h2 class="section-title">Evaluation Lenses</h2>
          <div class="lenses-stack">
            {judgeProfile.evaluationLenses.map(lens => (
              <div class="lens-card-item">
                <h3 class="lens-label">{lens.label}</h3>
                <p class="lens-question">“{lens.question}”</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Recent Verdicts Table -->
        {recentReviews.length > 0 && (
          <section class="profile-section">
            <h2 class="section-title">Recent Verdicts</h2>
            <p class="table-scroll-hint" aria-hidden="true">Scroll horizontally to see all columns →</p>
            {/* tabindex makes the scroll container reachable by keyboard, which is
                required for a scrollable region that holds content. */}
            <div
              class="verdicts-table-container"
              tabindex="0"
              role="region"
              aria-label="Recent verdicts, scrollable table"
            >
              <table class="verdicts-table">
                <thead>
                  <tr>
                    <th>Product</th>
                    <th class="text-right">Score</th>
                    <th class="text-right">Jury Avg</th>
                    <th class="text-right">Diff</th>
                    <th>Verdict Summary</th>
                  </tr>
                </thead>
                <tbody>
                  {recentReviews.map(r => (
                    <tr>
                      <td class="product-cell">
                        <a href={withBase(`/reviews/${r.slug}`)}>{r.productName}</a>
                      </td>
                      <td class="text-right tabular-nums font-bold">{r.judgeScore.toFixed(1)}</td>
                      <td class="text-right tabular-nums">{r.juryAverage.toFixed(1)}</td>
                      <td class={`text-right tabular-nums font-bold ${r.difference >= 0 ? 'diff-positive' : 'diff-negative'}`}>
                        {r.difference >= 0 ? '+' : ''}{r.difference.toFixed(1)}
                      </td>
                      <td class="verdict-summary-cell">{r.verdict}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}
      </div>

      <!-- Right Column: Preferences and Top Rated -->
      <div class="body-col-sidebar">
        <section class="profile-section sidebar-card">
          <h2 class="section-title">Expertise</h2>
          <div class="expertise-tags">
            {judgeProfile.expertise.map(e => (
              <span class="expertise-tag-item">{e}</span>
            ))}
          </div>
        </section>

        <section class="profile-section sidebar-card rewards-card">
          <h2 class="section-title text-positive">Rewards</h2>
          <ul class="pref-list">
            {judgeProfile.loves.map(l => (
              <li>
                <span class="pref-dot dot-positive">●</span>
                <p>{l}</p>
              </li>
            ))}
          </ul>
        </section>

        <section class="profile-section sidebar-card challenges-card">
          <h2 class="section-title text-critical">Challenges</h2>
          <ul class="pref-list">
            {judgeProfile.hates.map(h => (
              <li>
                <span class="pref-dot dot-critical">●</span>
                <p>{h}</p>
              </li>
            ))}
          </ul>
        </section>

        {rankedReviews.length > 0 && (
          <section class="profile-section sidebar-card ranking-preview-card">
            <h2 class="section-title">Top Rated Products</h2>
            <ol class="top-rated-ranking-list">
              {rankedReviews.map(r => {
                const judgeScore = r.review.evaluation.judges.find((j: any) => j.judge_id === judgeSlug)?.judge_score || 0;
                return (
                  <li>
                    <a href={withBase(`/reviews/${r.slug}`)} class="ranked-product-link">
                      {r.review.evaluation.product.name}
                    </a>
                    <span class="ranked-score tabular-nums">{judgeScore.toFixed(1)}</span>
                  </li>
                );
              })}
            </ol>
            <a href={withBase(`/rankings/judges/${judgeProfile.slug}/`)} class="sidebar-action-link">
              View full {judgeProfile.name} rankings →
            </a>
          </section>
        )}
      </div>
    </div>
  </div>
</Layout>

<style>
  .judge-profile-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  /* Profile Hero Header */
  .profile-hero {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-6) var(--space-8);
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: var(--space-8);
    margin-top: var(--space-4);
    align-items: center;
  }

  .hero-avatar-wrap {
    grid-row: 1 / 2;
  }

  .hero-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .persona-badge {
    font-family: var(--font-interface);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .profile-title {
    font-family: var(--font-editorial);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-ink);
    line-height: 1.1;
    margin: 0;
  }

  .profile-role {
    font-family: var(--font-interface);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-ink-muted);
    margin: 0;
  }

  .persona-provenance {
    font-family: var(--font-interface);
    font-size: 0.85rem;
    color: var(--color-ink-faint);
    margin-top: var(--space-1);
  }

  .persona-provenance a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .profile-lead-statement {
    grid-column: 1 / -1;
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    padding: var(--space-6);
    border-radius: var(--radius-sm);
  }

  .personality-text {
    font-family: var(--font-editorial);
    font-size: 1.15rem;
    font-style: italic;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.5;
  }

  /* Body Split Grid */
  .profile-body-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-8);
  }

  /* min-width:0 on both the grid track and the flex item: without it the 560px
     min-width of the verdicts table propagates outward and widens the page instead of
     being absorbed by the table's own scroll container. */
  .body-col-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    min-width: 0;
  }

  .profile-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-width: 0;
  }

  .section-title {
    font-family: var(--font-editorial);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-ink);
    border-bottom: 2px solid var(--color-ink);
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-1);
  }

  .text-positive {
    color: var(--color-positive);
    border-bottom-color: var(--color-positive);
  }

  .text-critical {
    color: var(--color-critical);
    border-bottom-color: var(--color-critical);
  }

  .section-text {
    font-family: var(--font-interface);
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Lenses Stack */
  .lenses-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .lens-card-item {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-sm);
  }

  .lens-label {
    font-family: var(--font-editorial);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0 0 var(--space-1);
  }

  .lens-question {
    font-family: var(--font-interface);
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    font-style: italic;
    margin: 0;
  }

  /* Verdicts Table — this horizontal scroll is intentional: the five columns are a
     comparison and must not be reflowed or truncated. It is kept, and signposted. */
  .verdicts-table-container {
    overflow-x: auto;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    /* Fades the right edge while there is more table to reach, so the region reads as
       scrollable rather than clipped. */
    background:
      linear-gradient(to right, var(--color-surface) 30%, rgba(255, 253, 248, 0)) left center,
      linear-gradient(to left, var(--color-surface) 30%, rgba(255, 253, 248, 0)) right center,
      radial-gradient(farthest-side at 0 50%, rgba(23, 32, 29, 0.14), rgba(23, 32, 29, 0)) left center,
      radial-gradient(farthest-side at 100% 50%, rgba(23, 32, 29, 0.14), rgba(23, 32, 29, 0)) right center;
    background-repeat: no-repeat;
    background-size: 40px 100%, 40px 100%, 14px 100%, 14px 100%;
    background-attachment: local, local, scroll, scroll;
  }

  .verdicts-table-container:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* The arrow only makes sense where the table actually overflows. */
  .table-scroll-hint {
    display: none;
    font-family: var(--font-interface);
    font-size: 0.78rem;
    color: var(--color-ink-faint);
    margin: 0 0 var(--space-2);
  }

  @media (max-width: 768px) {
    .table-scroll-hint {
      display: block;
    }
  }

  .verdicts-table {
    width: 100%;
    /* Below this the score columns collapse into unreadable slivers, so the container
       scrolls instead of squeezing. */
    min-width: 560px;
    border-collapse: collapse;
    font-family: var(--font-interface);
    font-size: 0.88rem;
    background: var(--color-surface);
  }

  .verdicts-table th, .verdicts-table td {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-canvas);
    text-align: left;
  }

  .verdicts-table th {
    background: var(--color-surface-muted);
    font-weight: 700;
    color: var(--color-ink);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
  }

  .verdicts-table tr:last-child td {
    border-bottom: none;
  }

  .product-cell a {
    color: var(--color-ink);
    font-weight: 700;
  }

  .product-cell a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .text-right {
    text-align: right;
  }

  .font-bold {
    font-weight: 700;
  }

  .diff-positive {
    color: var(--color-positive);
  }

  .diff-negative {
    color: var(--color-critical);
  }

  .verdict-summary-cell {
    color: var(--color-ink-muted);
    font-size: 0.82rem;
    max-width: 280px;
    line-height: 1.4;
  }

  /* Sidebar styling */
  .body-col-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    min-width: 0;
  }

  .sidebar-card {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    padding: var(--space-6);
    border-radius: var(--radius-sm);
  }

  .expertise-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .expertise-tag-item {
    background: var(--color-canvas);
    color: var(--color-ink-muted);
    font-family: var(--font-interface);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: var(--radius-lg);
  }

  .pref-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pref-list li {
    display: flex;
    gap: var(--space-2);
    align-items: flex-start;
  }

  .pref-dot {
    font-size: 0.6rem;
    margin-top: 4px;
  }

  .dot-positive { color: var(--color-positive); }
  .dot-critical { color: var(--color-critical); }

  .pref-list p {
    margin: 0;
    font-family: var(--font-interface);
    font-size: 0.88rem;
    color: var(--color-ink-muted);
    line-height: 1.4;
  }

  /* Top Rated product list */
  .top-rated-ranking-list {
    padding-left: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .top-rated-ranking-list li {
    font-family: var(--font-interface);
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px dashed var(--color-rule);
    padding-bottom: var(--space-2);
  }

  .top-rated-ranking-list li:last-child {
    border-bottom: none;
  }

  .ranked-product-link {
    color: var(--color-ink);
    font-weight: 600;
  }

  .ranked-product-link:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .ranked-score {
    font-weight: 700;
    color: var(--color-ink);
  }

  .sidebar-action-link {
    font-family: var(--font-interface);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-top: var(--space-2);
    display: inline-block;
  }

  .sidebar-action-link:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  /* Responsive Design */
  @media (max-width: 900px) {
    .profile-hero {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-4);
    }

    .hero-avatar-wrap {
      justify-self: center;
    }

    .profile-body-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
