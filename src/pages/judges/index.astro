---
import Layout from '../../layouts/Layout.astro';
import JudgeCard from '../../components/JudgeCard.astro';
import { getJudges } from '../../lib/jury';
import { withBase } from '../../lib/base';
import { brands } from '../../config/brands';
import { withUtm } from '../../lib/url';

const judges = getJudges();
---

<Layout
  title="Meet the Jury | JuryPress"
  description="Five AI judges. Five different definitions of a great product. Meet the Judgie-AI personas behind every JuryPress review."
>
  <div class="jury-index-layout">
    <header class="jury-hero">
      <h1 class="hero-title">Meet the Jury</h1>
      <p class="jury-lead">
        The five judges are fictional AI evaluation personas from 
        <a href={withUtm(brands.judgie.url, 'jury_page_judgie')} class="judgie-link" target="_blank" rel="noopener">{brands.judgie.name}</a>.
      </p>
      <p class="jury-sublead">
        They inspect the same evidence using the same hackathon rubric,
        but approach each product from different professional backgrounds, expertises, and values.
      </p>
    </header>

    <div class="judges-grid-section">
      <div class="judges-cards-grid">
        {judges.map(judge => (
          <JudgeCard judge={judge} variant="full" />
        ))}
      </div>
    </div>

    <div class="jury-cta-section">
      <div class="cta-inner-card">
        <h3>Use these judges with your own project</h3>
        <p>Run the same five AI personas with your own evidence and evaluation criteria using Judgie-AI.</p>
        <a href={withUtm(brands.judgie.url, 'jury_page_judgie')} class="btn-primary" target="_blank" rel="noopener">
          Explore {brands.judgie.name} →
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .jury-index-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .jury-hero {
    text-align: center;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: var(--space-8);
    margin-top: var(--space-4);
  }

  .hero-title {
    font-family: var(--font-editorial);
    font-size: 2.75rem;
    font-weight: 800;
    color: var(--color-ink);
    margin-bottom: var(--space-3);
  }

  .jury-lead {
    font-family: var(--font-interface);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-2);
  }

  .judgie-link {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .judgie-link:hover {
    color: var(--color-accent-hover);
  }

  .jury-sublead {
    font-family: var(--font-interface);
    font-size: 0.95rem;
    color: var(--color-ink-faint);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .judges-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 768px) {
    .judges-cards-grid {
      grid-template-columns: 1fr;
    }
  }

  .jury-cta-section {
    margin-top: var(--space-4);
  }

  .cta-inner-card {
    background: var(--color-surface);
    border: 1px solid var(--color-rule-strong);
    padding: var(--space-8);
    border-radius: var(--radius-sm);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .cta-inner-card h3 {
    font-family: var(--font-editorial);
    font-size: 1.4rem;
    color: var(--color-ink);
    margin: 0;
  }

  .cta-inner-card p {
    font-family: var(--font-interface);
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    max-width: 480px;
    margin: 0;
    line-height: 1.5;
  }

  .btn-primary {
    background: var(--color-ink);
    color: var(--color-canvas);
    font-family: var(--font-interface);
    font-weight: 700;
    font-size: 0.9rem;
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background-color 0.15s ease;
    margin-top: var(--space-2);
  }

  .btn-primary:hover {
    background: var(--color-accent);
  }
</style>
