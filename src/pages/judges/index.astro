---
import Layout from '../../layouts/Layout.astro';
import JudgeCard from '../../components/JudgeCard.astro';
import { getJudges } from '../../lib/jury';
import { withBase } from '../../lib/base';
import { brands } from '../../config/brands';
import { withUtm } from '../../lib/url';

const judges = getJudges();
---

<Layout
  title="Meet the Jury | JuryPress"
  description="Five AI judges. Five different definitions of a great product. Meet the Judgie-AI personas behind every JuryPress review."
>
  <div class="jury-page">
    <header class="jury-hero">
      <h1>Meet the Jury</h1>
      <p class="jury-lead">
        The five judges are fictional AI evaluation personas from <a href={withUtm(brands.judgie.url, 'jury_page_judgie')} class="judgie-link" target="_blank" rel="noopener">{brands.judgie.name}</a>.
      </p>
      <p class="jury-sublead">
        They inspect the same evidence using the same hackathon rubric,
        but approach each product from different professional backgrounds
        and values.
      </p>
    </header>

    <div class="judges-grid">
      {judges.map(judge => (
        <JudgeCard judge={judge} variant="full" />
      ))}
    </div>

    <div class="jury-cta-section">
      <p>Use these judges with your own project</p>
      <a href={withUtm(brands.judgie.url, 'jury_page_judgie')} class="jury-cta-link" target="_blank" rel="noopener">Explore {brands.judgie.name} →</a>
    </div>
  </div>
</Layout>

<style>
  .jury-page {
    padding: 1rem 0;
  }
  .jury-hero {
    text-align: center;
    padding: 2rem 0;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 2rem;
  }
  .jury-hero h1 {
    font-size: 2.25rem;
    color: #1a1a2e;
    margin-bottom: 0.75rem;
  }
  .jury-lead {
    font-size: 1.15rem;
    color: #1a1a2e;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .judgie-link {
    color: #c67c3b;
    text-decoration: none;
    font-weight: 700;
  }
  .judgie-link:hover { text-decoration: underline; }
  .jury-sublead {
    font-size: 0.95rem;
    color: #666;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .judges-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    padding-bottom: 2rem;
  }
  @media (max-width: 700px) {
    .judges-grid {
      grid-template-columns: 1fr;
    }
  }
  .jury-cta-section {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid #e5e5e5;
  }
  .jury-cta-section p {
    font-size: 1rem;
    color: #555;
    margin: 0 0 0.75rem;
  }
  .jury-cta-link {
    color: #c67c3b;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
  }
  .jury-cta-link:hover { text-decoration: underline; }
</style>
