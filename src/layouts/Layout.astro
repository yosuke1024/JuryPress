---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: object;
  isArticlePage?: boolean;
}

import { withBase } from '../lib/base';
import { brands } from '../config/brands';
import { withUtm } from '../lib/url';
import GlobalHeader from '../components/GlobalHeader.astro';
import JuryPressContextNavigation from '../components/JuryPressContextNavigation.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';

const { title, description = "JuryPress: The automated AI review media", ogImage, canonicalUrl, jsonLd, isArticlePage = false } = Astro.props;

const currentPath = Astro.url.pathname;

const siteUrl = Astro.site ? Astro.site.origin : 'https://pixapps.ai';
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
const ogImageUrl = ogImage ? `${siteUrl}${withBase(ogImage)}` : `${siteUrl}${withBase('/og-default.png')}`;
const ogUrl = canonical;

const noindex = import.meta.env.JURYPRESS_NOINDEX === 'true' || process.env.JURYPRESS_NOINDEX === 'true';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Global Header Styles -->
    <link rel="stylesheet" href={withBase('/global-header.css')} />

    <!-- Favicon -->
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />

    <!-- SEO & OGP -->
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content={isArticlePage ? "article" : "website"} />
    <meta name="twitter:card" content="summary_large_image" />
    <link class="canonical" rel="canonical" href={canonical} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow" />
    )}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    {import.meta.env.PUBLIC_GA_MEASUREMENT_ID && (
      <script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_MEASUREMENT_ID}`}></script>
      <script type="text/partytown" define:vars={{ gaId: import.meta.env.PUBLIC_GA_MEASUREMENT_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    )}
  </head>
  <body>
    <GlobalHeader />
    <JuryPressContextNavigation currentPath={currentPath} />

    <main class={isArticlePage ? "review-article-container" : "page-container"}>
      <slot />
    </main>

    <SiteFooter />
  </body>
</html>

<style>
  main {
    margin-top: 130px; /* Header height (112px) + content spacing */
    margin-bottom: var(--space-16);
    min-height: 80vh;
  }

  @media (max-width: 768px) {
    main {
      margin-top: 80px; /* Mobile header height (64px) + content spacing */
    }
  }
</style>
