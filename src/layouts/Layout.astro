---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: object;
  isArticlePage?: boolean;
}

import { withBase } from '../lib/base';
import { brands } from '../config/brands';
import { withUtm } from '../lib/url';
import GlobalHeader from '../components/GlobalHeader.astro';
import JuryPressContextNavigation from '../components/JuryPressContextNavigation.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';

const { title, description = "JuryPress: The automated AI review media", ogImage, canonicalUrl, jsonLd, isArticlePage = false } = Astro.props;

const currentPath = Astro.url.pathname;

const siteUrl = Astro.site ? Astro.site.origin : 'https://pixapps.ai';
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
const ogImageUrl = ogImage ? `${siteUrl}${withBase(ogImage)}` : `${siteUrl}${withBase('/og-default.png')}`;
const ogUrl = canonical;

const noindex = import.meta.env.JURYPRESS_NOINDEX === 'true' || process.env.JURYPRESS_NOINDEX === 'true';

// A missing CI variable resolves to '', and .env.example ships a G-XXXXXXXXXX placeholder;
// both must fail closed rather than emit a tag that silently collects nothing.
const rawGaId = (import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? '').trim();
const gaMeasurementId = /^G-[A-Z0-9]{6,}$/.test(rawGaId) && !/^G-X+$/.test(rawGaId) ? rawGaId : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Global Header Styles -->
    <link rel="stylesheet" href={withBase('/global-header.css')} />

    <!-- Favicon -->
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />

    <!-- SEO & OGP -->
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="JuryPress" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content={isArticlePage ? "article" : "website"} />
    <meta name="twitter:card" content="summary_large_image" />
    <link class="canonical" rel="canonical" href={canonical} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow" />
    )}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    {gaMeasurementId && (
      <script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
      <script type="text/partytown" define:vars={{ gaId: gaMeasurementId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId, { content_group: 'jurypress' });
      </script>
    )}
  </head>
  <body class="has-context-nav">
    <GlobalHeader />
    <JuryPressContextNavigation currentPath={currentPath} />

    <main class={isArticlePage ? "review-article-container" : "page-container"}>
      <slot />
    </main>

    <SiteFooter />
  </body>
</html>

<style>
  /* Fixed-chrome offset lives in exactly one place: `body.has-context-nav` in
     global-header.css reserves the height of the fixed chrome (64px global header on
     mobile, + 48px context navigation on desktop). `main` therefore only adds the
     breathing room between that chrome and the first line of content — it must not
     re-reserve the header height, which is what previously double-offset every page. */
  main {
    margin-top: var(--space-8);
    margin-bottom: var(--space-16);
    min-height: 80vh;
  }

  @media (max-width: 768px) {
    main {
      margin-top: var(--space-6); /* 24px below the 64px mobile header */
    }
  }
</style>
