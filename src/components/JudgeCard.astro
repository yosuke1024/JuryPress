---
import JudgeAvatar from './JudgeAvatar.astro';
import { withBase } from '../lib/base';
import type { JudgeProfile } from '../schemas/jury';

export interface Props {
  judge: JudgeProfile;
  variant?: 'full' | 'compact';
}

const { judge, variant = 'full' } = Astro.props;

const personalitySummary = judge.personalityAndTone.split('.').slice(0, 2).join('.').trim() + '.';
const primaryLenses = judge.evaluationLenses.map(l => l.label).join(' · ');
---

{variant === 'compact' ? (
  <div class="judge-card compact">
    <JudgeAvatar name={judge.name} role={judge.role} slug={judge.slug} size={56} />
    <h3 class="card-name">{judge.name}</h3>
    <p class="card-role">{judge.role}</p>
    <p class="card-lenses">{primaryLenses}</p>
    <a href={withBase(`/judges/${judge.slug}/`)} class="card-link">
      Meet {judge.name} →
    </a>
  </div>
) : (
  <div class="judge-card full">
    <div class="card-header">
      <JudgeAvatar name={judge.name} role={judge.role} slug={judge.slug} size={72} />
      <div class="card-identity">
        <h3 class="card-name">{judge.name}</h3>
        <p class="card-role">{judge.role}</p>
      </div>
    </div>

    <p class="card-personality">{personalitySummary}</p>

    <div class="card-section">
      <h4>Expertise</h4>
      <p class="card-expertise">{judge.expertise.join(', ')}</p>
    </div>

    <div class="card-lists">
      <div class="card-section">
        <h4>Rewards</h4>
        <ul>
          {judge.loves.slice(0, 2).map(l => <li>{l}</li>)}
        </ul>
      </div>
      <div class="card-section">
        <h4>Challenges</h4>
        <ul>
          {judge.hates.slice(0, 2).map(h => <li>{h}</li>)}
        </ul>
      </div>
    </div>

    <div class="card-section">
      <h4>Primary lenses</h4>
      <p class="card-lenses">{primaryLenses}</p>
    </div>

    <div class="card-actions">
      <a href={withBase(`/judges/${judge.slug}/`)} class="card-link">
        Meet {judge.name}
      </a>
      <a href={withBase(`/rankings/judges/${judge.slug}/`)} class="card-link secondary">
        {judge.name}'s Ranking
      </a>
    </div>
  </div>
)}

<style>
  .judge-card {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    padding: 1.5rem;
  }

  .judge-card.compact {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .judge-card.compact .card-name {
    margin: 0.5rem 0 0;
    font-size: 1.1rem;
  }
  .judge-card.compact .card-role {
    margin: 0;
    color: #666;
    font-size: 0.85rem;
  }
  .judge-card.compact .card-lenses {
    font-size: 0.8rem;
    color: #c67c3b;
    margin: 0.25rem 0 0.5rem;
  }
  .judge-card.compact .card-link {
    font-size: 0.85rem;
  }

  .judge-card.full {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .card-identity {
    flex: 1;
  }
  .card-name {
    margin: 0;
    font-size: 1.25rem;
    color: #1a1a2e;
  }
  .card-role {
    margin: 0.125rem 0 0;
    color: #666;
    font-size: 0.9rem;
  }
  .card-personality {
    color: #444;
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }
  .card-section h4 {
    margin: 0 0 0.25rem;
    font-size: 0.85rem;
    color: #1a1a2e;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .card-section ul {
    margin: 0;
    padding-left: 1.2rem;
    font-size: 0.88rem;
    color: #555;
  }
  .card-section ul li {
    margin-bottom: 0.2rem;
  }
  .card-expertise {
    font-size: 0.88rem;
    color: #555;
    margin: 0;
  }
  .card-lenses {
    font-size: 0.88rem;
    color: #c67c3b;
    font-weight: 600;
    margin: 0;
  }
  .card-lists {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .card-actions {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .card-link {
    color: #c67c3b;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .card-link:hover {
    text-decoration: underline;
  }
  .card-link.secondary {
    color: #666;
    font-weight: normal;
  }
</style>
