---
import JudgeAvatar from './JudgeAvatar.astro';
import { withBase } from '../lib/base';
import type { JudgeProfile } from '../schemas/jury';

export interface Props {
  judge: JudgeProfile;
  variant?: 'full' | 'compact';
}

const { judge, variant = 'full' } = Astro.props;

// 1-sentence summary of personality
const personalitySummary = judge.personalityAndTone.split(/[.!?]/).slice(0, 1).join('.').trim() + '.';
const primaryLenses = judge.evaluationLenses.map(l => l.label).join(' · ');
---

{variant === 'compact' ? (
  <div class="judge-card-editorial compact">
    <div class="avatar-container">
      <JudgeAvatar name={judge.name} role={judge.role} slug={judge.slug} size={56} />
    </div>
    <h3 class="judge-name">{judge.name}</h3>
    <p class="judge-role">{judge.role}</p>
    <p class="judge-lenses">{primaryLenses}</p>
    <a href={withBase(`/judges/${judge.slug}/`)} class="profile-link">
      Meet {judge.name} →
    </a>
  </div>
) : (
  <div class="judge-card-editorial full">
    <div class="card-header">
      <JudgeAvatar name={judge.name} role={judge.role} slug={judge.slug} size={64} />
      <div class="card-identity">
        <h3 class="judge-name">{judge.name}</h3>
        <p class="judge-role">{judge.role}</p>
        <span class="persona-tag">Fictional AI Judge</span>
      </div>
    </div>

    <div class="card-body">
      <p class="judge-personality">{personalitySummary}</p>
      <div class="lenses-section">
        <span class="lenses-label">PRIMARY LENSES</span>
        <p class="judge-lenses">{primaryLenses}</p>
      </div>
    </div>

    <div class="card-footer-links">
      <a href={withBase(`/judges/${judge.slug}/`)} class="meet-link">
        Meet {judge.name} →
      </a>
      <a href={withBase(`/rankings/judges/${judge.slug}/`)} class="rank-link">
        View Rankings
      </a>
    </div>
  </div>
)}

<style>
  .judge-card-editorial {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease;
  }

  .judge-card-editorial:hover {
    border-color: var(--color-rule-strong);
  }

  .judge-name {
    font-family: var(--font-editorial);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0;
  }

  .judge-role {
    font-family: var(--font-interface);
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin: 0;
  }

  .judge-lenses {
    font-family: var(--font-interface);
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 600;
    margin: 0;
    line-height: 1.4;
  }

  /* Compact View (Homepage Grid) */
  .judge-card-editorial.compact {
    align-items: center;
    text-align: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-2);
  }

  .avatar-container {
    margin-bottom: var(--space-1);
  }

  .judge-card-editorial.compact .judge-name {
    font-size: 1.1rem;
  }

  .judge-card-editorial.compact .judge-role {
    font-size: 0.8rem;
  }

  .judge-card-editorial.compact .profile-link {
    font-family: var(--font-interface);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-ink);
    margin-top: var(--space-2);
  }

  .judge-card-editorial.compact .profile-link:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* Full View (Jury List Page) */
  .judge-card-editorial.full {
    gap: var(--space-4);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  .card-identity {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .persona-tag {
    font-family: var(--font-interface);
    font-size: 0.7rem;
    color: var(--color-ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: var(--space-1);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .judge-personality {
    font-family: var(--font-interface);
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    line-height: 1.5;
    margin: 0;
  }

  .lenses-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .lenses-label {
    font-family: var(--font-interface);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-ink-faint);
    letter-spacing: 0.08em;
  }

  .card-footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
    min-width: 0;
    font-family: var(--font-interface);
    font-size: 0.85rem;
    margin-top: var(--space-2);
    border-top: 1px solid var(--color-canvas);
    padding-top: var(--space-3);
  }

  .meet-link {
    font-weight: 700;
    color: var(--color-accent);
  }

  .rank-link {
    font-weight: 500;
    color: var(--color-ink-muted);
  }
</style>
