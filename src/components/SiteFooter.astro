---
import { withBase } from '../lib/base';
import { brands } from '../config/brands';
import { withUtm } from '../lib/url';
---

<footer class="site-footer">
  <div class="footer-content">
    <div class="attribution-section">
      <p class="attribution-main">
        JuryPress is an autonomous media experiment by 
        <a href={withUtm(brands.pixapps.url, 'footer_pixapps')} target="_blank" rel="noopener" class="brand-link">{brands.pixapps.name}</a>.
      </p>
      <p class="attribution-sub">
        Jury personas and the evaluation rubric come from 
        <a href={withUtm(brands.judgie.url, 'footer_judgie')} target="_blank" rel="noopener" class="brand-link">{brands.judgie.name}</a>.
      </p>
      <p class="attribution-status">
        A PixApps experiment · AUTONOMOUS MEDIA EXPERIMENT · HUMAN EDITING DISCLOSED
      </p>
    </div>

    <hr class="footer-rule" />

    <div class="footer-bottom">
      <p class="copyright">
        &copy; {new Date().getFullYear()} JuryPress. Editorial content and branding reserved.<br class="footer-br-mobile" />
        Source code licensed under MIT.
      </p>
      <div class="footer-nav" role="navigation" aria-label="Footer navigation">
        <a href={withBase('/reviews/')}>Reviews</a>
        <a href={withBase('/rankings/')}>Rankings</a>
        <a href={withBase('/judges/')}>The Jury</a>
        <a href={withBase('/rubric/')}>Rubric</a>
        <a href={withBase('/methodology/')}>Methodology</a>
        <a href={withBase('/about/')}>About</a>
        <a href={withBase('/licensing/')}>Licensing</a>
        <a href={withBase('/privacy/')}>Privacy</a>
        <a href={withBase('/rss.xml')}>RSS</a>
        <a href="https://github.com/yosuke1024/JuryPress" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-rule);
    padding: var(--space-12) var(--space-4) var(--space-8);
    margin-top: var(--space-16);
    color: var(--color-ink-muted);
  }

  .footer-content {
    max-width: var(--width-page);
    margin: 0 auto;
  }

  .attribution-section {
    max-width: 600px;
    margin-bottom: var(--space-8);
  }

  .attribution-main {
    font-family: var(--font-editorial);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-ink);
    line-height: 1.4;
    margin-bottom: var(--space-2);
  }

  .attribution-sub {
    font-family: var(--font-interface);
    font-size: 0.9rem;
    color: var(--color-ink-faint);
  }

  .attribution-status {
    font-family: var(--font-interface);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-ink-faint);
    margin-top: var(--space-2);
    text-transform: uppercase;
  }

  .brand-link {
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: var(--color-rule-strong);
  }

  .brand-link:hover {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }

  .footer-rule {
    border: none;
    border-top: 1px solid var(--color-rule);
    margin-bottom: var(--space-6);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .copyright {
    font-family: var(--font-interface);
    font-size: 0.85rem;
    color: var(--color-ink-faint);
  }

  .footer-br-mobile {
    display: none;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer-nav a {
    font-family: var(--font-interface);
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-nav a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .footer-br-mobile {
      display: inline;
    }

    .site-footer {
      padding: var(--space-8) var(--space-4) var(--space-6);
    }
    
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }

    .footer-nav {
      gap: var(--space-3) var(--space-4);
    }
  }
</style>
