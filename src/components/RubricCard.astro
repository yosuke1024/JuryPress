---
import type { RubricCriterion } from '../schemas/jury';

export interface Props {
  criterion: RubricCriterion;
}

const { criterion } = Astro.props;
const exampleRaw = 4.0;
const exampleWeighted = (exampleRaw / 5) * criterion.weight;
---

<div class="rubric-card-editorial">
  <div class="rubric-card-header">
    <h3 class="rubric-card-title">{criterion.name}</h3>
    <span class="rubric-card-weight tabular-nums">{criterion.weight}%</span>
  </div>

  <div class="rubric-card-section">
    <span class="section-tag">WHAT JUDGES EVALUATE</span>
    <ul class="rubric-list">
      {criterion.whatJudgesEvaluate.map(item => <li>{item}</li>)}
    </ul>
  </div>

  <div class="rubric-card-section">
    <span class="section-tag tag-positive">SIGNALS OF A STRONG SUBMISSION</span>
    <ul class="rubric-list">
      {criterion.strongSignals.map(item => <li>{item}</li>)}
    </ul>
  </div>

  <div class="rubric-card-formula-block">
    <span class="section-tag">SCORE FORMULA</span>
    <code class="formula-code">Weighted Score = Raw Score ÷ 5 × {criterion.weight}</code>
    <p class="formula-example">
      A raw score of {exampleRaw.toFixed(1)} contributes <strong class="tabular-nums">{exampleWeighted.toFixed(0)} points</strong>.
    </p>
  </div>
</div>

<style>
  .rubric-card-editorial {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    height: auto; /* Allow items to stretch naturally */
  }

  .rubric-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: var(--space-3);
  }

  .rubric-card-title {
    font-family: var(--font-editorial);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-ink);
    text-transform: capitalize;
    margin: 0;
  }

  .rubric-card-weight {
    font-family: var(--font-interface);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-accent);
  }

  .rubric-card-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .section-tag {
    font-family: var(--font-interface);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-ink-faint);
    letter-spacing: 0.08em;
  }

  .tag-positive {
    color: var(--color-positive);
  }

  .rubric-list {
    margin: 0;
    padding-left: var(--space-4);
    font-family: var(--font-interface);
    font-size: 0.88rem;
    color: var(--color-ink-muted);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    line-height: 1.5;
  }

  .rubric-card-formula-block {
    margin-top: var(--space-2);
    border-top: 1px solid var(--color-canvas);
    padding-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .formula-code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: var(--color-canvas);
    color: var(--color-ink);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    display: block;
    line-height: 1.4;
    word-break: break-all;
  }

  .formula-example {
    font-family: var(--font-interface);
    font-size: 0.82rem;
    color: var(--color-ink-muted);
    margin: 0;
  }

  .formula-example strong {
    color: var(--color-ink);
  }
</style>
