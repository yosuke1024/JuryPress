---
import JudgeAvatar from './JudgeAvatar.astro';
import { withBase } from '../lib/base';
import { getJudges } from '../lib/jury';
import { JUDGE_SLUGS } from '../schemas/jury';

export interface Props {
  judge: any;
}

const { judge } = Astro.props;

// Validate judge_id against SSOT
const validSlugs: readonly string[] = JUDGE_SLUGS;
if (!validSlugs.includes(judge.judge_id)) {
  throw new Error(`Unknown judge_id in review JSON: "${judge.judge_id}". Valid IDs: ${validSlugs.join(', ')}`);
}

const judgeProfiles = getJudges();
const profile = judgeProfiles.find(j => j.slug === judge.judge_id);

const primaryConcern = judge.concerns && judge.concerns.length > 0 ? judge.concerns[0] : 'No critical concerns raised.';
---

<div class="scorecard-editorial">
  <div class="scorecard-header">
    <div class="judge-meta-wrap">
      <JudgeAvatar
        name={judge.judge_name}
        role={judge.role}
        slug={judge.judge_id}
        size={56}
      />
      <div class="judge-identity">
        <h3 class="judge-name">{judge.judge_name}</h3>
        <p class="judge-role">{judge.role}</p>
      </div>
    </div>
    
    <div class="score-badge-wrap">
      <span class="score-label">SCORE</span>
      <span class="score-val tabular-nums">{judge.judge_score?.toFixed(1)}</span>
    </div>
  </div>

  <div class="scorecard-body">
    <div class="verdict-section">
      <span class="section-tag">VERDICT</span>
      <p class="verdict-text">{judge.verdict}</p>
    </div>

    <div class="evaluation-highlights">
      <div class="highlight-block strengths">
        <span class="section-tag tag-strengths">KEY STRENGTHS</span>
        <ul class="highlight-list">
          {judge.strengths?.slice(0, 3).map((s: string) => (
            <li>{s}</li>
          ))}
        </ul>
      </div>

      <div class="highlight-block concerns">
        <span class="section-tag tag-concerns">PRIMARY CONCERN</span>
        <p class="highlight-text">{primaryConcern}</p>

        {judge.recommended_next_step && (
          <div class="next-step-block">
            <span class="section-tag tag-next-step">RECOMMENDED NEXT STEP</span>
            <p class="next-step-action">{judge.recommended_next_step.action}</p>
            <div class="next-step-meta">
              <span class="next-step-criterion">Criterion: {judge.recommended_next_step.criterion_id.replace(/_/g, ' ')}</span>
              {judge.recommended_next_step.evidence_ids && judge.recommended_next_step.evidence_ids.length > 0 && (
                <span class="next-step-evidence">Evidence: {judge.recommended_next_step.evidence_ids.join(', ')}</span>
              )}
            </div>
          </div>
        )}
      </div>
    </div>

    {judge.decisive_question && (
      <div class="decisive-question-block">
        <span class="section-tag">DECISIVE QUESTION</span>
        <blockquote class="question-quote">“{judge.decisive_question}”</blockquote>
      </div>
    )}
  </div>

  <div class="scorecard-footer-links">
    <a href={withBase(`/judges/${judge.judge_id}/`)} class="meet-link">
      Meet {judge.judge_name} →
    </a>
    <a href={withBase(`/rankings/judges/${judge.judge_id}/`)} class="rank-link">
      View {judge.judge_name}'s Rankings
    </a>
  </div>

  <!-- Detailed scorecard expandable -->
  <details class="detailed-score-disclosure">
    <summary class="disclosure-trigger">
      <span class="trigger-text">View full scorecard</span>
      <span class="trigger-icon"></span>
    </summary>
    <div class="disclosure-content">
      <div class="criteria-grid">
        {judge.criteria?.map((c: any) => (
          <div class="criterion-row">
            <div class="criterion-header">
              <span class="criterion-id">{c.criterion_id.replace(/_/g, ' ')}</span>
              <div class="criterion-score-wrap">
                <span class="criterion-score tabular-nums">{c.score} / 5</span>
                <span class="criterion-weighted tabular-nums">(Weighted: {c.weighted_score?.toFixed(1)})</span>
              </div>
            </div>
            <p class="criterion-reasoning">{c.reasoning}</p>
            <div class="criterion-meta">
              <span class="confidence-tag">Confidence: {c.confidence}</span>
              {c.evidence_ids && c.evidence_ids.length > 0 && (
                <span class="evidence-tag">Evidence: {c.evidence_ids.join(', ')}</span>
              )}
            </div>
            {c.limitations && c.limitations.length > 0 && (
              <div class="criterion-limitations">
                <span class="limitations-label">Limitations:</span>
                <ul class="limitations-list">
                  {c.limitations.map((l: string) => <li>{l}</li>)}
                </ul>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </details>
</div>

<style>
  .scorecard-editorial {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    padding: var(--space-6);
    margin-bottom: var(--space-8);
    box-shadow: none;
    transition: border-color 0.25s ease;
  }

  .scorecard-editorial:hover {
    border-color: var(--color-rule-strong);
  }

  .scorecard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: var(--space-4);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .judge-meta-wrap {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  .judge-identity {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .judge-name {
    font-family: var(--font-editorial);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0;
  }

  .judge-role {
    font-family: var(--font-interface);
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin: 0;
  }

  .score-badge-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .score-label {
    font-family: var(--font-interface);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-ink-faint);
    letter-spacing: 0.08em;
  }

  .score-val {
    font-family: var(--font-interface);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-ink);
    line-height: 1;
  }

  .scorecard-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .section-tag {
    font-family: var(--font-interface);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-ink-faint);
    letter-spacing: 0.08em;
    display: block;
    margin-bottom: var(--space-2);
  }

  .tag-strengths {
    color: var(--color-positive);
  }

  .tag-concerns {
    color: var(--color-critical);
  }

  .verdict-text {
    font-family: var(--font-interface);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0;
  }

  .evaluation-highlights {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .highlight-block {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .highlight-list {
    margin: 0;
    padding-left: var(--space-4);
    font-family: var(--font-interface);
    font-size: 0.92rem;
    color: var(--color-ink-muted);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .highlight-text {
    font-family: var(--font-interface);
    font-size: 0.92rem;
    color: var(--color-ink-muted);
    margin: 0;
  }

  /* Recommended next step (2.1.0 reviews): nested under the primary concern so the
     action reads as the direct answer to that concern. */
  .next-step-block {
    margin-top: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-canvas);
    border-left: 3px solid var(--color-positive);
    border-radius: var(--radius-sm);
  }

  .tag-next-step {
    color: var(--color-positive);
  }

  .next-step-action {
    font-family: var(--font-interface);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.5;
  }

  .next-step-meta {
    margin-top: var(--space-2);
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    min-width: 0;
    font-family: var(--font-interface);
    font-size: 0.78rem;
  }

  /* Evidence ID lists are joined into one string and can exceed the card width. */
  .next-step-criterion, .next-step-evidence {
    background: var(--color-surface-muted);
    color: var(--color-ink-muted);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-weight: 500;
    text-transform: capitalize;
    max-width: 100%;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .next-step-evidence {
    text-transform: none;
  }

  .decisive-question-block {
    background: var(--color-canvas);
    padding: var(--space-4);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--color-rule-strong);
  }

  .question-quote {
    font-family: var(--font-editorial);
    font-size: 1rem;
    font-style: italic;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.5;
  }

  /* Both links embed the judge name, so the row wraps to a second line on narrow
     screens instead of overflowing the card. */
  .scorecard-footer-links {
    margin-top: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    min-width: 0;
    font-family: var(--font-interface);
    font-size: 0.85rem;
    border-bottom: 1px solid var(--color-canvas);
    padding-bottom: var(--space-4);
  }

  .scorecard-footer-links a {
    font-weight: 600;
    color: var(--color-accent);
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .scorecard-footer-links a.rank-link {
    color: var(--color-ink-muted);
    font-weight: 500;
  }

  /* Expandable full scorecard */
  .detailed-score-disclosure {
    border: none;
    border-radius: 0;
    background: transparent;
    margin-top: var(--space-4);
  }

  .disclosure-trigger {
    padding: var(--space-2) 0;
    color: var(--color-ink);
    font-family: var(--font-interface);
    font-size: 0.9rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .disclosure-trigger:hover {
    color: var(--color-accent);
  }

  .trigger-icon::after {
    content: "↓";
    font-size: 1rem;
    font-weight: bold;
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .detailed-score-disclosure[open] .trigger-icon::after {
    transform: rotate(180deg);
  }

  .disclosure-content {
    padding: var(--space-4) 0 0;
  }

  .criteria-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .criterion-row {
    background: var(--color-surface-muted);
    padding: var(--space-4);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-rule);
  }

  .criterion-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .criterion-id {
    font-family: var(--font-editorial);
    font-size: 1rem;
    font-weight: 700;
    text-transform: capitalize;
    color: var(--color-ink);
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .criterion-score-wrap {
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
  }

  .criterion-score {
    font-weight: 700;
    color: var(--color-ink);
    font-size: 0.95rem;
  }

  .criterion-weighted {
    color: var(--color-ink-muted);
    font-size: 0.8rem;
  }

  .criterion-reasoning {
    font-family: var(--font-interface);
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-3);
    line-height: 1.5;
  }

  .criterion-meta {
    display: flex;
    gap: var(--space-4);
    font-family: var(--font-interface);
    font-size: 0.8rem;
    flex-wrap: wrap;
  }

  /* "Evidence: EV-001, EV-002, …" grows with the number of cited IDs. */
  .confidence-tag, .evidence-tag {
    background: var(--color-canvas);
    color: var(--color-ink-muted);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-weight: 500;
    max-width: 100%;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .criterion-limitations {
    margin-top: var(--space-3);
    border-top: 1px dashed var(--color-rule);
    padding-top: var(--space-2);
  }

  .limitations-label {
    font-family: var(--font-interface);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-ink-faint);
  }

  .limitations-list {
    margin: var(--space-1) 0 0;
    padding-left: var(--space-4);
    font-family: var(--font-interface);
    font-size: 0.8rem;
    color: var(--color-ink-faint);
  }

  @media (max-width: 768px) {
    .evaluation-highlights {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
