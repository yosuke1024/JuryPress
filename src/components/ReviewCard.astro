---
import { getConsensus } from '../lib/verdict';
import { withBase } from '../lib/base';

export interface Props {
  slug: string;
  productName: string;
  headline: string;
  standfirst?: string;
  juryScore: number;
  judgeRange: { min: number; max: number };
  source?: string;
  publishedAt: string;
  variant?: 'large' | 'compact';
  displayScore?: number;
  displayScoreLabel?: string;
  /** Marks a published review that is outside the current ranking standard. */
  historical?: boolean;
}

const { slug, productName, headline, standfirst, juryScore, judgeRange, source, publishedAt, variant = 'compact', displayScore, displayScoreLabel = 'JURY SCORE', historical = false } = Astro.props;
const date = new Date(publishedAt).toISOString().split('T')[0];

const { label: consensusLabel, className: consensusClass } = getConsensus(judgeRange);
---

<div class={`review-card-editorial ${variant}`}>
  <div class="card-body">
    <div class="card-top-meta">
      {source && <span class="card-source">{source}</span>}
      <span class="card-date tabular-nums">{date}</span>
      {historical && <span class="card-historical">Historical methodology</span>}
    </div>
    
    <h3 class="card-product">
      <a href={withBase(`/reviews/${slug}`)}>{productName}</a>
    </h3>
    
    {variant === 'large' && <p class="card-headline">{headline}</p>}
    {variant === 'large' && standfirst && <p class="card-standfirst">{standfirst}</p>}

    <div class="card-score-summary">
      <div class="score-item">
        <span class="score-label">{displayScoreLabel}</span>
        <span class="score-value tabular-nums">{(displayScore !== undefined && displayScore !== null ? displayScore : juryScore).toFixed(1)}</span>
      </div>
      <div class="score-item">
        <span class="score-label">RANGE</span>
        <span class="score-range tabular-nums">{judgeRange.min.toFixed(1)}–{judgeRange.max.toFixed(1)}</span>
      </div>
      <div class="score-item">
        <span class="score-label">VERDICT</span>
        <span class={`consensus-badge ${consensusClass}`}>{consensusLabel}</span>
      </div>
    </div>
  </div>

  <div class="card-actions">
    <a href={withBase(`/reviews/${slug}`)} class="verdict-link">
      Read Verdict <span class="arrow">→</span>
    </a>
  </div>
</div>

<style>
  .review-card-editorial {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    padding: var(--space-6);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-6);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .review-card-editorial:hover {
    border-color: var(--color-rule-strong);
  }

  .review-card-editorial.large {
    flex-direction: column;
    align-items: stretch;
    padding: var(--space-8);
  }

  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .card-top-meta {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    font-family: var(--font-interface);
    font-size: 0.75rem;
    font-weight: 500;
  }

  .card-source {
    background: var(--color-canvas);
    color: var(--color-ink-muted);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-date {
    color: var(--color-ink-faint);
  }

  /* Neutral by design: the review is not wrong, it is outside the current comparison. */
  .card-historical {
    background: var(--color-canvas);
    color: var(--color-ink-muted);
    border: 1px solid var(--color-rule);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.68rem;
    font-weight: 700;
  }

  .card-product {
    font-family: var(--font-editorial);
    font-size: 1.35rem;
    font-weight: 800;
    margin: 0;
  }

  .card-product a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .card-product a:hover {
    color: var(--color-accent);
  }

  .card-headline {
    font-family: var(--font-interface);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-ink-muted);
    margin: var(--space-2) 0 0;
    line-height: 1.4;
  }

  .card-standfirst {
    font-family: var(--font-interface);
    font-size: 0.92rem;
    color: var(--color-ink-muted);
    margin: 0;
    line-height: 1.6;
  }

  .card-score-summary {
    display: flex;
    gap: var(--space-6);
    margin-top: var(--space-4);
    align-items: flex-end;
    flex-wrap: wrap;
  }

  .score-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .score-label {
    font-family: var(--font-interface);
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--color-ink-faint);
    letter-spacing: 0.08em;
  }

  .score-value {
    font-family: var(--font-interface);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-ink);
    line-height: 1;
  }

  .score-range {
    font-family: var(--font-interface);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-ink-muted);
  }

  .consensus-badge {
    font-family: var(--font-interface);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .consensus-strong, .consensus-general {
    background: #e8f5e9;
    color: var(--color-positive);
  }

  .consensus-split {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .consensus-divisive {
    background: #fde8e8;
    color: var(--color-critical);
  }

  .card-actions {
    display: flex;
    align-items: center;
  }

  .verdict-link {
    font-family: var(--font-interface);
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-accent);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .verdict-link:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  .arrow {
    transition: transform 0.15s ease;
  }

  .verdict-link:hover .arrow {
    transform: translateX(3px);
  }

  /* Large variant responsive adjustments */
  .review-card-editorial.large .card-product {
    font-size: 1.75rem;
  }

  .review-card-editorial.large .score-value {
    font-size: 2rem;
  }

  .review-card-editorial.large .card-actions {
    align-self: flex-start;
    margin-top: var(--space-4);
  }

  @media (max-width: 600px) {
    .review-card-editorial {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }
    
    .card-actions {
      align-self: flex-start;
    }
  }
</style>
